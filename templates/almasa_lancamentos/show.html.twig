{% extends 'base.html.twig' %}

{% block title %}Lançamento Almasa #{{ lancamento.id }} - {{ parent() }}{% endblock %}

{% block content %}
<div class="container-fluid">
    {% include '_partials/breadcrumb.html.twig' with {
        'items': [
            {'label': 'Financeiro', 'url': '#'},
            {'label': 'Lançamentos Almasa', 'url': path('app_almasa_lancamentos_index')}
        ],
        'current': '#' ~ lancamento.id
    } %}
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h1><i class="fas fa-cash-register"></i> Lançamento Almasa #{{ lancamento.id }}</h1>
                <div>
                    <a href="{{ path('app_almasa_lancamentos_edit', {'id': lancamento.id}) }}" class="btn btn-warning">
                        <i class="fas fa-edit"></i> Editar
                    </a>
                    <a href="{{ path('app_almasa_lancamentos_index') }}" class="btn btn-secondary ms-2">
                        <i class="fas fa-arrow-left"></i> Voltar
                    </a>
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <table class="table table-borderless">
                                <tr>
                                    <th width="200">ID:</th>
                                    <td>{{ lancamento.id }}</td>
                                </tr>
                                <tr>
                                    <th>Tipo:</th>
                                    <td>
                                        {% if lancamento.tipo == 'receita' %}
                                            <span class="badge bg-success">Receita</span>
                                        {% else %}
                                            <span class="badge bg-danger">Despesa</span>
                                        {% endif %}
                                    </td>
                                </tr>
                                <tr>
                                    <th>Conta:</th>
                                    <td>
                                        {% if lancamento.almasaPlanoConta %}
                                            <a href="{{ path('app_almasa_plano_contas_show', {'id': lancamento.almasaPlanoConta.id}) }}">
                                                {{ lancamento.almasaPlanoConta.codigo }} - {{ lancamento.almasaPlanoConta.descricao }}
                                            </a>
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                </tr>
                                <tr>
                                    <th>Descrição:</th>
                                    <td>{{ lancamento.descricao ?? '—' }}</td>
                                </tr>
                                <tr>
                                    <th>Valor:</th>
                                    <td><strong>R$ {{ lancamento.valor|number_format(2, ',', '.') }}</strong></td>
                                </tr>
                                <tr>
                                    <th>Status:</th>
                                    <td>
                                        <span class="badge bg-{{ lancamento.statusBadgeClass }}">
                                            {{ lancamento.statusLabel }}
                                        </span>
                                    </td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <table class="table table-borderless">
                                <tr>
                                    <th width="200">Data Competência:</th>
                                    <td>{{ lancamento.dataCompetencia|date('d/m/Y') }}</td>
                                </tr>
                                <tr>
                                    <th>Data Vencimento:</th>
                                    <td>{{ lancamento.dataVencimento ? lancamento.dataVencimento|date('d/m/Y') : '—' }}</td>
                                </tr>
                                <tr>
                                    <th>Data Pagamento:</th>
                                    <td>{{ lancamento.dataPagamento ? lancamento.dataPagamento|date('d/m/Y') : '—' }}</td>
                                </tr>
                                <tr>
                                    <th>Conta Bancária:</th>
                                    <td>{{ lancamento.contaBancaria ? lancamento.contaBancaria.descricao : '—' }}</td>
                                </tr>
                                <tr>
                                    <th>Observação:</th>
                                    <td>{{ lancamento.observacao ?? '—' }}</td>
                                </tr>
                                <tr>
                                    <th>Criado em:</th>
                                    <td>{{ lancamento.createdAt|date('d/m/Y H:i') }}</td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    {% if lancamento.lancamentoOrigem %}
                    <div class="alert alert-info">
                        <i class="fas fa-link"></i>
                        Originado automaticamente do lançamento do cliente
                        <strong>#{{ lancamento.lancamentoOrigem.id }}</strong>
                        — {{ lancamento.lancamentoOrigem.historico ?? 'Sem histórico' }}
                        — R$ {{ lancamento.lancamentoOrigem.valor|number_format(2, ',', '.') }}
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
