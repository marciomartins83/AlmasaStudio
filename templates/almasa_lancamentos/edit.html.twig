{% extends 'base.html.twig' %}

{% block title %}Editar Lançamento Almasa - {{ parent() }}{% endblock %}

{% block content %}
<div class="container-fluid">
    {% include '_partials/breadcrumb.html.twig' with {
        'items': [
            {'label': 'Financeiro', 'url': '#'},
            {'label': 'Lançamentos Almasa', 'url': path('app_almasa_lancamentos_index')}
        ],
        'current': 'Editar #' ~ lancamento.id
    } %}
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h1><i class="fas fa-edit"></i> Editar Lançamento Almasa #{{ lancamento.id }}</h1>
                <div>
                    <a href="{{ path('app_almasa_lancamentos_show', {'id': lancamento.id}) }}" class="btn btn-info">
                        <i class="fas fa-eye"></i> Visualizar
                    </a>
                    <a href="{{ path('app_almasa_lancamentos_index') }}" class="btn btn-secondary ms-2">
                        <i class="fas fa-arrow-left"></i> Voltar
                    </a>
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': true}}) }}
                        <div class="row">
                            <div class="col-md-2">
                                {{ form_row(form.tipo) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_row(form.almasaPlanoConta) }}
                            </div>
                            <div class="col-md-3">
                                {{ form_row(form.descricao) }}
                            </div>
                            <div class="col-md-3">
                                {{ form_row(form.valor) }}
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-3">
                                {{ form_row(form.dataCompetencia) }}
                            </div>
                            <div class="col-md-3">
                                {{ form_row(form.dataVencimento) }}
                            </div>
                            <div class="col-md-3">
                                {{ form_row(form.dataPagamento) }}
                            </div>
                            <div class="col-md-3">
                                {{ form_row(form.status) }}
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4">
                                {{ form_row(form.contaBancaria) }}
                            </div>
                            <div class="col-md-8">
                                {{ form_row(form.observacao) }}
                            </div>
                        </div>

                        {% if lancamento.lancamentoOrigem %}
                        <div class="alert alert-info mt-3">
                            <i class="fas fa-link"></i>
                            Originado do lançamento do cliente <strong>#{{ lancamento.lancamentoOrigem.id }}</strong>
                            (gerado automaticamente)
                        </div>
                        {% endif %}

                        <div class="row mt-3">
                            <div class="col-12">
                                <button type="submit" class="btn btn-success">
                                    <i class="fas fa-save"></i> Salvar Alterações
                                </button>
                                <a href="{{ path('app_almasa_lancamentos_show', {'id': lancamento.id}) }}" class="btn btn-info ms-2">
                                    <i class="fas fa-eye"></i> Ver
                                </a>
                                <a href="{{ path('app_almasa_lancamentos_index') }}" class="btn btn-secondary ms-2">
                                    <i class="fas fa-times"></i> Cancelar
                                </a>
                            </div>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
