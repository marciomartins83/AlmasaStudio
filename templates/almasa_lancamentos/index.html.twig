{% extends 'base.html.twig' %}

{% block title %}Lançamentos Almasa - {{ parent() }}{% endblock %}

{% block content %}
<div class="container-fluid">
    {% include '_partials/breadcrumb.html.twig' with {
        'items': [
            {'label': 'Financeiro', 'url': '#'}
        ],
        'current': 'Lançamentos Almasa'
    } %}
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h1><i class="fas fa-cash-register"></i> Lançamentos Almasa</h1>
                <a href="{{ path('app_almasa_lancamentos_new') }}" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Novo Lançamento
                </a>
            </div>

            {% include '_partials/search_panel.html.twig' with {
                filterDefs: pagination.filterDefs,
                filters: pagination.filters,
                routeName: 'app_almasa_lancamentos_index',
                itemsPerPage: pagination.itemsPerPage,
                sortField: pagination.sortField,
                sortDir: pagination.sortDir
            } %}

            {% include '_partials/sort_panel.html.twig' with {
                sortOptions: pagination.sortOptions,
                sortField: pagination.sortField,
                sortDir: pagination.sortDir,
                routeName: 'app_almasa_lancamentos_index',
                filters: pagination.filters,
                itemsPerPage: pagination.itemsPerPage
            } %}

            <div class="card">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th width="60">ID</th>
                                    <th width="100">Tipo</th>
                                    <th>Conta</th>
                                    <th>Descrição</th>
                                    <th width="120" class="text-end">Valor</th>
                                    <th width="110">Competência</th>
                                    <th width="100">Status</th>
                                    <th width="180">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in pagination.items %}
                                <tr>
                                    <td>{{ item.id }}</td>
                                    <td>
                                        {% if item.tipo == 'receita' %}
                                            <span class="badge bg-success">Receita</span>
                                        {% else %}
                                            <span class="badge bg-danger">Despesa</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if item.almasaPlanoConta %}
                                            <code>{{ item.almasaPlanoConta.codigo }}</code>
                                            <small class="text-muted">{{ item.almasaPlanoConta.descricao }}</small>
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ item.descricao ?? '—' }}</td>
                                    <td class="text-end">
                                        <strong>R$ {{ item.valor|number_format(2, ',', '.') }}</strong>
                                    </td>
                                    <td>{{ item.dataCompetencia|date('d/m/Y') }}</td>
                                    <td>
                                        <span class="badge bg-{{ item.statusBadgeClass }}">
                                            {{ item.statusLabel }}
                                        </span>
                                    </td>
                                    <td>
                                        <div class="btn-group d-none d-md-flex" role="group">
                                            <a href="{{ path('app_almasa_lancamentos_show', {'id': item.id}) }}"
                                               class="btn btn-info btn-sm">
                                                <i class="fas fa-eye"></i> Ver
                                            </a>
                                            <a href="{{ path('app_almasa_lancamentos_edit', {'id': item.id}) }}"
                                               class="btn btn-warning btn-sm">
                                                <i class="fas fa-edit"></i> Editar
                                            </a>
                                            <form method="post"
                                                  action="{{ path('app_almasa_lancamentos_delete', {'id': item.id}) }}"
                                                  style="display:inline-block"
                                                  data-confirm-delete="Tem certeza que deseja excluir este lançamento?">
                                                <input type="hidden" name="_token"
                                                       value="{{ csrf_token('delete' ~ item.id) }}">
                                                <button class="btn btn-danger btn-sm">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                                {% else %}
                                <tr>
                                    <td colspan="8" class="text-center text-muted py-4">
                                        <i class="fas fa-info-circle fa-2x mb-2 d-block"></i>
                                        Nenhum lançamento Almasa cadastrado
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>

                    {% include '_partials/pagination.html.twig' with {
                        totalItems: pagination.totalItems,
                        currentPage: pagination.currentPage,
                        itemsPerPage: pagination.itemsPerPage,
                        totalPages: pagination.totalPages,
                        search: pagination.search,
                        routeName: 'app_almasa_lancamentos_index',
                        filters: pagination.filters,
                        sortField: pagination.sortField,
                        sortDir: pagination.sortDir,
                        showSearch: false
                    } %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('crud_filters') }}
{% endblock %}
