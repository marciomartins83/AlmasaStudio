{% extends 'base.html.twig' %}

{% block title %}{{ plano_contas.codigo }} - {{ plano_contas.descricao }} - {{ parent() }}{% endblock %}

{% block content %}
<div class="container-fluid">
    {% include '_partials/breadcrumb.html.twig' with {
        'items': [
            {'label': 'Tipos', 'url': path('app_dashboard_tipos_index')},
            {'label': 'Tipo de Lançamentos', 'url': path('app_plano_contas_index')}
        ],
        'current': 'Ver Tipo de Lançamentos'
    } %}
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h1><i class="fas fa-list-alt"></i> {{ plano_contas.codigo }} — {{ plano_contas.descricao }}</h1>
                <div>
                    <a href="{{ path('app_plano_contas_edit', {'id': plano_contas.id}) }}" class="btn btn-warning">
                        <i class="fas fa-edit"></i> Editar
                    </a>
                    <a href="{{ path('app_plano_contas_index') }}" class="btn btn-secondary ms-2">
                        <i class="fas fa-arrow-left"></i> Voltar
                    </a>
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <table class="table table-borderless">
                                <tr>
                                    <th width="200">ID:</th>
                                    <td>{{ plano_contas.id }}</td>
                                </tr>
                                <tr>
                                    <th>Código:</th>
                                    <td><code>{{ plano_contas.codigo }}</code></td>
                                </tr>
                                <tr>
                                    <th>Descrição:</th>
                                    <td><strong>{{ plano_contas.descricao }}</strong></td>
                                </tr>
                                <tr>
                                    <th>Tipo:</th>
                                    <td>
                                        {% if plano_contas.tipo == 0 %}
                                            <span class="badge bg-success">Receita</span>
                                        {% elseif plano_contas.tipo == 1 %}
                                            <span class="badge bg-danger">Despesa</span>
                                        {% elseif plano_contas.tipo == 2 %}
                                            <span class="badge bg-warning text-dark">Transitória</span>
                                        {% else %}
                                            <span class="badge bg-secondary">Caixa</span>
                                        {% endif %}
                                    </td>
                                </tr>
                                <tr>
                                    <th>Código Contábil:</th>
                                    <td>{{ plano_contas.codigoContabil ?? '—' }}</td>
                                </tr>
                                <tr>
                                    <th>Ativo:</th>
                                    <td>
                                        {% if plano_contas.isAtivo() %}
                                            <i class="fas fa-check-circle text-success"></i> Sim
                                        {% else %}
                                            <i class="fas fa-times-circle text-danger"></i> Não
                                        {% endif %}
                                    </td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <table class="table table-borderless">
                                <tr>
                                    <th width="230">Incide Taxa de Administração:</th>
                                    <td>{{ plano_contas.isIncideTaxaAdmin() ? 'Sim' : 'Não' }}</td>
                                </tr>
                                <tr>
                                    <th>Incide IR:</th>
                                    <td>{{ plano_contas.isIncideIr() ? 'Sim' : 'Não' }}</td>
                                </tr>
                                <tr>
                                    <th>Entra no Informe:</th>
                                    <td>{{ plano_contas.isEntraInforme() ? 'Sim' : 'Não' }}</td>
                                </tr>
                                <tr>
                                    <th>Entra no Desconto:</th>
                                    <td>{{ plano_contas.isEntraDesconto() ? 'Sim' : 'Não' }}</td>
                                </tr>
                                <tr>
                                    <th>Entra na Multa:</th>
                                    <td>{{ plano_contas.isEntraMulta() ? 'Sim' : 'Não' }}</td>
                                </tr>
                                <tr>
                                    <th>Criado em:</th>
                                    <td>{{ plano_contas.createdAt|date('d/m/Y H:i') }}</td>
                                </tr>
                                <tr>
                                    <th>Atualizado em:</th>
                                    <td>{{ plano_contas.updatedAt|date('d/m/Y H:i') }}</td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
