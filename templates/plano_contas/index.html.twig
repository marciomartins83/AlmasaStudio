{% extends 'base.html.twig' %}

{% block title %}Tipo de Lançamentos - {{ parent() }}{% endblock %}

{% block content %}
<div class="container-fluid">
    {% include '_partials/breadcrumb.html.twig' with {
        'items': [
            {'label': 'Tipos', 'url': path('app_dashboard_tipos_index')}
        ],
        'current': 'Tipo de Lançamentos'
    } %}
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h1><i class="fas fa-list-alt"></i> Tipo de Lançamentos</h1>
                <a href="{{ path('app_plano_contas_new') }}" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Novo Tipo de Lançamentos
                </a>
            </div>

            {% include '_partials/search_panel.html.twig' with {
                filterDefs: pagination.filterDefs,
                filters: pagination.filters,
                routeName: 'app_plano_contas_index',
                itemsPerPage: pagination.itemsPerPage,
                sortField: pagination.sortField,
                sortDir: pagination.sortDir
            } %}

            {% include '_partials/sort_panel.html.twig' with {
                sortOptions: pagination.sortOptions,
                sortField: pagination.sortField,
                sortDir: pagination.sortDir,
                routeName: 'app_plano_contas_index',
                filters: pagination.filters,
                itemsPerPage: pagination.itemsPerPage
            } %}

            <div class="card">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th width="80">ID</th>
                                    <th width="120">Código</th>
                                    <th>Descrição</th>
                                    <th width="120">Tipo</th>
                                    <th width="80" class="text-center">Ativo</th>
                                    <th width="200">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in pagination.items %}
                                <tr>
                                    <td>{{ item.id }}</td>
                                    <td><code>{{ item.codigo }}</code></td>
                                    <td><strong>{{ item.descricao }}</strong></td>
                                    <td>
                                        {% if item.tipo == 0 %}
                                            <span class="badge bg-success">Receita</span>
                                        {% elseif item.tipo == 1 %}
                                            <span class="badge bg-danger">Despesa</span>
                                        {% elseif item.tipo == 2 %}
                                            <span class="badge bg-warning text-dark">Transitória</span>
                                        {% else %}
                                            <span class="badge bg-secondary">Caixa</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-center">
                                        {% if item.isAtivo() %}
                                            <i class="fas fa-check-circle text-success"></i>
                                        {% else %}
                                            <i class="fas fa-times-circle text-danger"></i>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <div class="btn-group d-none d-md-flex" role="group">
                                            <a href="{{ path('app_plano_contas_show', {'id': item.id}) }}"
                                               class="btn btn-info btn-sm">
                                                <i class="fas fa-eye"></i> Ver
                                            </a>
                                            <a href="{{ path('app_plano_contas_edit', {'id': item.id}) }}"
                                               class="btn btn-warning btn-sm">
                                                <i class="fas fa-edit"></i> Editar
                                            </a>
                                            <form method="post"
                                                  action="{{ path('app_plano_contas_delete', {'id': item.id}) }}"
                                                  style="display:inline-block"
                                                  data-confirm-delete="Tem certeza que deseja excluir este tipo de lançamentos?">
                                                <input type="hidden" name="_token"
                                                       value="{{ csrf_token('delete' ~ item.id) }}">
                                                <button class="btn btn-danger btn-sm">
                                                    <i class="fas fa-trash"></i> Excluir
                                                </button>
                                            </form>
                                        </div>
                                        <div class="btn-group-vertical btn-group-sm d-md-none" role="group">
                                            <a href="{{ path('app_plano_contas_show', {'id': item.id}) }}"
                                               class="btn btn-info btn-sm">
                                                <i class="fas fa-eye"></i> Ver
                                            </a>
                                            <a href="{{ path('app_plano_contas_edit', {'id': item.id}) }}"
                                               class="btn btn-warning btn-sm">
                                                <i class="fas fa-edit"></i> Editar
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                                {% else %}
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">
                                        <i class="fas fa-info-circle fa-2x mb-2 d-block"></i>
                                        <span>Nenhum tipo de lançamentos cadastrado</span><br>
                                        <small>Clique em "Novo Tipo de Lançamentos" para começar</small>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>

                    {% include '_partials/pagination.html.twig' with {
                        totalItems: pagination.totalItems,
                        currentPage: pagination.currentPage,
                        itemsPerPage: pagination.itemsPerPage,
                        totalPages: pagination.totalPages,
                        search: pagination.search,
                        routeName: 'app_plano_contas_index',
                        filters: pagination.filters,
                        sortField: pagination.sortField,
                        sortDir: pagination.sortDir,
                        showSearch: false
                    } %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('crud_filters') }}
{% endblock %}
