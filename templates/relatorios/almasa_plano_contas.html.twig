{% extends 'base.html.twig' %}

{% block title %}Plano de Contas Almasa - {{ parent() }}{% endblock %}

{% block content %}
<div class="container-fluid">
    {% include '_partials/breadcrumb.html.twig' with {
        'items': [
            {'label': 'Dashboard', 'url': path('app_dashboard')},
            {'label': 'Relatorios', 'url': path('app_relatorios_index')}
        ],
        'current': 'Plano de Contas Almasa'
    } %}

    <div class="row">
        {# Filtros #}
        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-secondary text-white">
                    <i class="fas fa-filter"></i> Filtros — Plano de Contas Almasa
                </div>
                <div class="card-body">
                    <form id="formFiltros">
                        <div class="mb-3">
                            <label for="tipo" class="form-label">Tipo</label>
                            <select class="form-select" id="tipo" name="tipo">
                                <option value="todos">Todos</option>
                                <option value="ativo">Ativo</option>
                                <option value="passivo">Passivo</option>
                                <option value="patrimonio_liquido">Patrimônio Líquido</option>
                                <option value="receita">Receita</option>
                                <option value="despesa">Despesa</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="nivel" class="form-label">Nivel</label>
                            <select class="form-select" id="nivel" name="nivel">
                                <option value="todos">Todos (Integral)</option>
                                <option value="1">Classe</option>
                                <option value="2">Grupo</option>
                                <option value="3">Subgrupo</option>
                                <option value="4">Conta</option>
                                <option value="5">Subconta</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="ativo" class="form-label">Status</label>
                            <select class="form-select" id="ativo" name="ativo">
                                <option value="todos">Todos</option>
                                <option value="ativos" selected>Ativos</option>
                                <option value="inativos">Inativos</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="aceita_lancamentos" class="form-label">Aceita Lancamentos</label>
                            <select class="form-select" id="aceita_lancamentos" name="aceita_lancamentos">
                                <option value="todos">Todos</option>
                                <option value="sim">Sim</option>
                                <option value="nao">Nao</option>
                            </select>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="button" id="btnPreview" class="btn btn-primary">
                                <i class="fas fa-search"></i> Preview
                            </button>
                            <button type="button" id="btnPdf" class="btn btn-danger" disabled>
                                <i class="fas fa-file-pdf"></i> Gerar PDF
                            </button>
                            <a href="{{ path('app_relatorios_index') }}" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left"></i> Voltar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        {# Preview #}
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <i class="fas fa-eye"></i> Preview do Relatorio
                </div>
                <div class="card-body" id="previewContent">
                    <div class="text-center text-muted py-5">
                        <i class="fas fa-info-circle fa-3x mb-3"></i>
                        <p>Preencha os filtros e clique em "Preview" para visualizar o relatorio.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    window.ROUTES = {
        preview: '{{ path('app_relatorios_almasa_plano_contas_preview') }}',
        pdf: '{{ path('app_relatorios_almasa_plano_contas_pdf') }}'
    };
    window.RELATORIO_TIPO = 'almasa_plano_contas';
</script>
{{ encore_entry_script_tags('relatorios') }}
{% endblock %}
