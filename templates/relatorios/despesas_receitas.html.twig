{% extends 'base.html.twig' %}

{% block title %}Relatório Despesas x Receitas - {{ parent() }}{% endblock %}

{% block content %}
<div class="container-fluid">
    {% include '_partials/breadcrumb.html.twig' with {
        'items': [
            {'label': 'Dashboard', 'url': path('app_dashboard')},
            {'label': 'Relatórios', 'url': path('app_relatorios_index')}
        ],
        'current': 'Despesas x Receitas'
    } %}

    <div class="row">
        {# Filtros #}
        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <i class="fas fa-filter"></i> Filtros
                </div>
                <div class="card-body">
                    <form id="formFiltros">
                        <div class="row mb-3">
                            <div class="col-6">
                                <label for="data_inicio" class="form-label">Data Inicio</label>
                                <input type="date" class="form-control" id="data_inicio" name="data_inicio"
                                       value="{{ "first day of this month"|date('Y-m-d') }}" required>
                            </div>
                            <div class="col-6">
                                <label for="data_fim" class="form-label">Data Fim</label>
                                <input type="date" class="form-control" id="data_fim" name="data_fim"
                                       value="{{ "now"|date('Y-m-d') }}" required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="tipo_data" class="form-label">Tipo de Data</label>
                            <select class="form-select" id="tipo_data" name="tipo_data">
                                <option value="vencimento">Vencimento</option>
                                <option value="pagamento">Pagamento</option>
                                <option value="competencia">Competência</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="status" class="form-label">Status</label>
                            <select class="form-select" id="status" name="status">
                                <option value="todos">Todos</option>
                                <option value="efetivado">Apenas Efetivados (Pagos)</option>
                            </select>
                        </div>

                        {% include '_partials/imovel_autocomplete_field.html.twig' with {
                            fieldId: 'id_imovel',
                            label: 'Imóvel',
                            placeholder: 'Todos — ou código/endereço...'
                        } %}

                        {% include '_partials/pessoa_autocomplete_field.html.twig' with {
                            fieldId: 'id_proprietario',
                            label: 'Proprietário',
                            placeholder: 'Todos — ou digite nome/código...'
                        } %}

                        <div class="mb-3">
                            <label for="visualizacao" class="form-label">Visualização</label>
                            <select class="form-select" id="visualizacao" name="visualizacao">
                                <option value="sintetico">Sintético</option>
                                <option value="analitico">Analítico</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="agrupar_por" class="form-label">Agrupar por</label>
                            <select class="form-select" id="agrupar_por" name="agrupar_por">
                                <option value="plano_conta">Tipo de Lançamento</option>
                                <option value="mes">Mês</option>
                                <option value="imovel">Imóvel</option>
                            </select>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="button" id="btnPreview" class="btn btn-primary">
                                <i class="fas fa-search"></i> Preview
                            </button>
                            <button type="button" id="btnPdf" class="btn btn-danger" disabled>
                                <i class="fas fa-file-pdf"></i> Gerar PDF
                            </button>
                            <a href="{{ path('app_relatorios_index') }}" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left"></i> Voltar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        {# Preview #}
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <i class="fas fa-eye"></i> Preview do Relatorio
                </div>
                <div class="card-body" id="previewContent">
                    <div class="text-center text-muted py-5">
                        <i class="fas fa-info-circle fa-3x mb-3"></i>
                        <p>Preencha os filtros e clique em "Preview" para visualizar o relatório.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    window.ROUTES = {
        preview: '{{ path('app_relatorios_despesas_receitas_preview') }}',
        pdf: '{{ path('app_relatorios_despesas_receitas_pdf') }}'
    };
    window.RELATORIO_TIPO = 'despesas_receitas';
</script>
{{ encore_entry_script_tags('relatorios') }}
{{ encore_entry_script_tags('pessoa_autocomplete') }}
{% endblock %}
