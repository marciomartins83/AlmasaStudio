{# Preview Receitas Almasa #}
<div class="table-responsive">
    <table class="table table-striped table-hover table-sm">
        <thead class="table-dark">
            <tr>
                <th>Data</th>
                <th>Plano de Contas</th>
                <th>Descrição</th>
                <th class="text-end">Valor</th>
                <th class="text-center">Status</th>
            </tr>
        </thead>
        <tbody>
            {% if dados is iterable and dados|length > 0 %}
                {% set primeiro = dados|first %}
                {% if primeiro.itens is defined %}
                    {# Dados agrupados #}
                    {% for chave, grupo in dados %}
                        <tr class="table-secondary">
                            <td colspan="5"><strong>{{ grupo.nome }}</strong></td>
                        </tr>
                        {% for item in grupo.itens %}
                            <tr>
                                <td>{{ item.dataCompetencia|date('d/m/Y') }}</td>
                                <td>{{ item.planoConta }}</td>
                                <td>{{ item.descricao|length > 50 ? item.descricao|slice(0, 50) ~ '...' : item.descricao }}</td>
                                <td class="text-end">R$ {{ item.valor|number_format(2, ',', '.') }}</td>
                                <td class="text-center">
                                    <span class="badge bg-{{ item.statusBadgeClass }}">{{ item.statusLabel }}</span>
                                </td>
                            </tr>
                        {% endfor %}
                        <tr class="table-success">
                            <td colspan="3" class="text-end"><strong>Subtotal:</strong></td>
                            <td class="text-end fw-bold">R$ {{ grupo.total|number_format(2, ',', '.') }}</td>
                            <td></td>
                        </tr>
                    {% endfor %}
                {% else %}
                    {# Dados nao agrupados #}
                    {% for item in dados %}
                        <tr>
                            <td>{{ item.dataCompetencia|date('d/m/Y') }}</td>
                            <td>{{ item.planoConta }}</td>
                            <td>{{ item.descricao|length > 50 ? item.descricao|slice(0, 50) ~ '...' : item.descricao }}</td>
                            <td class="text-end">R$ {{ item.valor|number_format(2, ',', '.') }}</td>
                            <td class="text-center">
                                <span class="badge bg-{{ item.statusBadgeClass }}">{{ item.statusLabel }}</span>
                            </td>
                        </tr>
                    {% endfor %}
                {% endif %}
            {% else %}
                <tr>
                    <td colspan="5" class="text-center text-muted py-4">
                        <i class="fas fa-info-circle fa-2x mb-2"></i><br>
                        Nenhuma receita Almasa encontrada com os filtros selecionados.
                    </td>
                </tr>
            {% endif %}
        </tbody>
        {% if totais.quantidade > 0 %}
        <tfoot class="table-primary">
            <tr>
                <td colspan="3" class="text-end"><strong>TOTAIS ({{ totais.quantidade }} registros):</strong></td>
                <td class="text-end"><strong>R$ {{ totais.total_geral|number_format(2, ',', '.') }}</strong></td>
                <td></td>
            </tr>
            <tr class="table-light">
                <td colspan="3" class="text-end">Em Aberto:</td>
                <td class="text-end text-warning">R$ {{ totais.total_aberto|number_format(2, ',', '.') }}</td>
                <td></td>
            </tr>
            <tr class="table-light">
                <td colspan="3" class="text-end">Recebido:</td>
                <td class="text-end text-success">R$ {{ totais.total_pago|number_format(2, ',', '.') }}</td>
                <td></td>
            </tr>
        </tfoot>
        {% endif %}
    </table>
</div>
