{# Preview Extrato de Conta Corrente do Proprietário #}
{% if dados is empty %}
    <div class="alert alert-warning">Nenhum dado encontrado para os filtros selecionados.</div>
{% else %}

{% for extrato in dados %}
{# Identificação do proprietário #}
<div class="card mb-1 border-secondary">
    <div class="card-body py-2" style="font-size:13px;">
        <strong>Proprietário:</strong> {{ extrato.proprietario.cod }} - {{ extrato.proprietario.nome }}
        {% if extrato.proprietario.cnpj %}
            &nbsp;&nbsp;<strong>CNPJ:</strong> {{ extrato.proprietario.cnpj }}
        {% elseif extrato.proprietario.cpf %}
            &nbsp;&nbsp;<strong>CPF:</strong> {{ extrato.proprietario.cpf }}
        {% endif %}
    </div>
</div>

{# Tabela principal #}
<div class="table-responsive mb-4">
    <table class="table table-bordered table-sm" style="font-size:12px;">
        <thead class="table-dark">
            <tr>
                <th>Histórico</th>
                <th class="text-end" width="120">Débito</th>
                <th class="text-end" width="120">Crédito</th>
            </tr>
        </thead>
        <tbody>

            {# Saldo Anterior #}
            <tr>
                <td>Saldo Anterior</td>
                <td></td>
                <td class="text-end fw-bold">{{ extrato.saldo_anterior|number_format(2, ',', '.') }}</td>
            </tr>

            {# PAGAMENTOS #}
            <tr class="table-secondary">
                <td colspan="3" class="text-center fw-bold">PAGAMENTOS</td>
            </tr>
            {% for pag in extrato.pagamentos %}
            <tr>
                <td>{{ pag.data|date('d/m') }} {{ pag.historico }}</td>
                <td class="text-end text-danger">{{ pag.valor|number_format(2, ',', '.') }}</td>
                <td></td>
            </tr>
            {% else %}
            <tr><td colspan="3" class="text-center text-muted fst-italic">Nenhum pagamento no período</td></tr>
            {% endfor %}
            <tr class="table-light">
                <td colspan="2" class="text-end fw-bold">SUBTOTAL:</td>
                <td class="text-end fw-bold text-danger">-{{ extrato.total_pagamentos|number_format(2, ',', '.') }}</td>
            </tr>

            {# MOVIMENTAÇÃO #}
            <tr class="table-secondary">
                <td colspan="3" class="text-center fw-bold">MOVIMENTAÇÃO</td>
            </tr>
            {% for grupo in extrato.movimentacao %}
            <tr class="table-light">
                <td colspan="3" class="text-center fw-bold">
                    Imóvel: {{ grupo.imovel_cod }} - {{ grupo.imovel_endereco }}
                </td>
            </tr>
            <tr>
                <td colspan="3" class="fst-italic ps-3">
                    Inquilino(a): {{ grupo.inquilino_nome }}
                    {% if grupo.proximo_reajuste %}
                        &nbsp;&nbsp;Próx. Reaj.: {{ grupo.proximo_reajuste|date('d/m/Y') }}
                    {% endif %}
                </td>
            </tr>
            {% for lanc in grupo.lancamentos %}
            <tr>
                <td class="ps-4">{{ lanc.data|date('d/m') }} {{ lanc.historico }}</td>
                <td></td>
                <td class="text-end text-success">{{ lanc.valor|number_format(2, ',', '.') }}</td>
            </tr>
            {% endfor %}
            <tr class="table-light">
                <td colspan="2" class="text-end fw-bold">SUBTOTAL:</td>
                <td class="text-end fw-bold text-success">{{ grupo.subtotal|number_format(2, ',', '.') }}</td>
            </tr>
            {% else %}
            <tr><td colspan="3" class="text-center text-muted fst-italic">Nenhuma movimentação no período</td></tr>
            {% endfor %}

            {# Saldo Atual #}
            <tr class="table-primary">
                <td colspan="2" class="text-end fw-bold">Saldo Atual:</td>
                <td class="text-end fw-bold {% if extrato.saldo_atual >= 0 %}text-success{% else %}text-danger{% endif %}">
                    {{ extrato.saldo_atual|number_format(2, ',', '.') }}
                </td>
            </tr>

        </tbody>
    </table>
</div>
{% endfor %}

{% endif %}
