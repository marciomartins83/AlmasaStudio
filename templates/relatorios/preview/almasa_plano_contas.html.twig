{# Preview Plano de Contas Almasa #}
<div class="table-responsive">
    <table class="table table-striped table-hover table-sm">
        <thead class="table-dark">
            <tr>
                <th width="120">Codigo</th>
                <th>Descricao</th>
                <th width="100" class="text-center">Tipo</th>
                <th width="100" class="text-center">Nivel</th>
                <th width="80" class="text-center">Aceita Lanc.</th>
                <th width="80" class="text-center">Status</th>
                <th width="150">Pai</th>
            </tr>
        </thead>
        <tbody>
            {% if dados is iterable and dados|length > 0 %}
                {% for conta in dados %}
                    <tr>
                        <td>
                            <code>
                                {% if conta.nivel == 1 %}
                                    <strong>{{ conta.codigo }}</strong>
                                {% elseif conta.nivel == 2 %}
                                    &nbsp;&nbsp;{{ conta.codigo }}
                                {% else %}
                                    &nbsp;&nbsp;&nbsp;&nbsp;{{ conta.codigo }}
                                {% endif %}
                            </code>
                        </td>
                        <td>
                            {% if conta.nivel == 1 %}
                                <strong class="text-dark">{{ conta.descricao }}</strong>
                            {% elseif conta.nivel == 2 %}
                                <span class="text-secondary">&nbsp;&nbsp;{{ conta.descricao }}</span>
                            {% else %}
                                &nbsp;&nbsp;&nbsp;&nbsp;{{ conta.descricao }}
                            {% endif %}
                        </td>
                        <td class="text-center">
                            {% if conta.tipo == 'receita' %}
                                <span class="badge bg-success">Receita</span>
                            {% else %}
                                <span class="badge bg-danger">Despesa</span>
                            {% endif %}
                        </td>
                        <td class="text-center">
                            <span class="badge bg-{{ conta.nivel == 1 ? 'dark' : (conta.nivel == 2 ? 'secondary' : 'info') }}">
                                {{ conta.nivelLabel }}
                            </span>
                        </td>
                        <td class="text-center">
                            {% if conta.isAceitaLancamentos() %}
                                <i class="fas fa-check-circle text-success"></i>
                            {% else %}
                                <i class="fas fa-minus-circle text-muted"></i>
                            {% endif %}
                        </td>
                        <td class="text-center">
                            {% if conta.isAtivo() %}
                                <span class="badge bg-success">Ativo</span>
                            {% else %}
                                <span class="badge bg-secondary">Inativo</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if conta.pai %}
                                <small class="text-muted">{{ conta.pai.codigo }} - {{ conta.pai.descricao }}</small>
                            {% else %}
                                <small class="text-muted">-</small>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            {% else %}
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">
                        <i class="fas fa-info-circle fa-2x mb-2"></i><br>
                        Nenhuma conta encontrada com os filtros selecionados.
                    </td>
                </tr>
            {% endif %}
        </tbody>
        <tfoot class="table-light">
            <tr>
                <td colspan="7">
                    <strong>Total: {{ dados|length }} conta(s) encontrada(s)</strong>
                </td>
            </tr>
        </tfoot>
    </table>
</div>

{# Legenda #}
<div class="mt-3">
    <small class="text-muted">
        <strong>Legenda:</strong>
        <span class="badge bg-success ms-2">Receita</span>
        <span class="badge bg-danger ms-1">Despesa</span>
        &nbsp;|&nbsp;
        <span class="badge bg-dark ms-1">Grupo</span>
        <span class="badge bg-secondary ms-1">Subgrupo</span>
        <span class="badge bg-info ms-1">Conta</span>
    </small>
</div>
