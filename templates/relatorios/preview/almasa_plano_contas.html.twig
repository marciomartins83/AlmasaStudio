{# Preview Plano de Contas Almasa #}
<div class="table-responsive">
    <table class="table table-striped table-hover table-sm">
        <thead class="table-dark">
            <tr>
                <th width="120">Codigo</th>
                <th>Descricao</th>
                <th width="100" class="text-center">Tipo</th>
                <th width="100" class="text-center">Nivel</th>
                <th width="80" class="text-center">Aceita Lanc.</th>
                <th width="80" class="text-center">Status</th>
                <th width="150">Pai</th>
            </tr>
        </thead>
        <tbody>
            {% if dados is iterable and dados|length > 0 %}
                {% for conta in dados %}
                    <tr>
                        <td>
                            <code>
                                {% set indent = '&nbsp;&nbsp;'|repeat(conta.nivel - 1) %}
                                {% if conta.nivel <= 2 %}
                                    <strong>{{ indent|raw }}{{ conta.codigo }}</strong>
                                {% else %}
                                    {{ indent|raw }}{{ conta.codigo }}
                                {% endif %}
                            </code>
                        </td>
                        <td>
                            {% set indent = '&nbsp;&nbsp;'|repeat(conta.nivel - 1) %}
                            {% if conta.nivel == 1 %}
                                <strong class="text-dark">{{ conta.descricao }}</strong>
                            {% elseif conta.nivel == 2 %}
                                <strong class="text-secondary">{{ indent|raw }}{{ conta.descricao }}</strong>
                            {% else %}
                                <span class="text-{{ conta.nivel >= 4 ? 'body' : 'secondary' }}">{{ indent|raw }}{{ conta.descricao }}</span>
                            {% endif %}
                        </td>
                        <td class="text-center">
                            {% set tipoBadge = {
                                'ativo': 'primary',
                                'passivo': 'warning',
                                'patrimonio_liquido': 'info',
                                'receita': 'success',
                                'despesa': 'danger'
                            } %}
                            <span class="badge bg-{{ tipoBadge[conta.tipo] ?? 'secondary' }}">{{ conta.tipoLabel }}</span>
                        </td>
                        <td class="text-center">
                            {% set nivelBadge = { 1: 'dark', 2: 'secondary', 3: 'info', 4: 'primary', 5: 'light text-dark' } %}
                            <span class="badge bg-{{ nivelBadge[conta.nivel] ?? 'secondary' }}">
                                {{ conta.nivelLabel }}
                            </span>
                        </td>
                        <td class="text-center">
                            {% if conta.isAceitaLancamentos() %}
                                <i class="fas fa-check-circle text-success"></i>
                            {% else %}
                                <i class="fas fa-minus-circle text-muted"></i>
                            {% endif %}
                        </td>
                        <td class="text-center">
                            {% if conta.isAtivo() %}
                                <span class="badge bg-success">Ativo</span>
                            {% else %}
                                <span class="badge bg-secondary">Inativo</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if conta.pai %}
                                <small class="text-muted">{{ conta.pai.codigo }} - {{ conta.pai.descricao }}</small>
                            {% else %}
                                <small class="text-muted">-</small>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            {% else %}
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">
                        <i class="fas fa-info-circle fa-2x mb-2"></i><br>
                        Nenhuma conta encontrada com os filtros selecionados.
                    </td>
                </tr>
            {% endif %}
        </tbody>
        <tfoot class="table-light">
            <tr>
                <td colspan="7">
                    <strong>Total: {{ dados|length }} conta(s) encontrada(s)</strong>
                </td>
            </tr>
        </tfoot>
    </table>
</div>

{# Legenda #}
<div class="mt-3">
    <small class="text-muted">
        <strong>Tipo:</strong>
        <span class="badge bg-primary ms-2">Ativo</span>
        <span class="badge bg-warning ms-1">Passivo</span>
        <span class="badge bg-info ms-1">Patrim. Liq.</span>
        <span class="badge bg-success ms-1">Receita</span>
        <span class="badge bg-danger ms-1">Despesa</span>
        &nbsp;|&nbsp;
        <strong>Nivel:</strong>
        <span class="badge bg-dark ms-1">Classe</span>
        <span class="badge bg-secondary ms-1">Grupo</span>
        <span class="badge bg-info ms-1">Subgrupo</span>
        <span class="badge bg-primary ms-1">Conta</span>
        <span class="badge bg-light text-dark ms-1">Subconta</span>
    </small>
</div>
