<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Extrato do Proprietario</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: DejaVu Sans, sans-serif; font-size: 10px; line-height: 1.4; color: #333; }
        .container { padding: 15px; }
        table { width: 100%; border-collapse: collapse; }
        th, td { border: 1px solid #ccc; padding: 3px 6px; }
        .text-right { text-align: right; }
        .text-center { text-align: center; }
        .text-danger { color: #c00; }
        .text-success { color: #070; }
        .bold { font-weight: bold; }
        .italic { font-style: italic; }
        /* Bloco do proprietário */
        .prop-block { border: 1px solid #aaa; padding: 6px 8px; margin-bottom: 10px; font-size: 9px; }
        .prop-block .prop-row { margin: 2px 0; }
        /* Seções da tabela */
        .row-saldo-ant { background: #f5f5f5; }
        .row-section { background: #555; color: #fff; text-align: center; font-weight: bold; }
        .row-imovel { background: #ddd; text-align: center; font-weight: bold; }
        .row-inquilino { font-style: italic; background: #f9f9f9; }
        .row-lancamento td:first-child { padding-left: 16px; }
        .row-subtotal { background: #eee; font-weight: bold; }
        .row-saldo-atual { background: #333; color: #fff; font-weight: bold; font-size: 11px; }
        .col-hist { width: 68%; }
        .col-debito { width: 16%; text-align: right; }
        .col-credito { width: 16%; text-align: right; }
    </style>
</head>
<body>
<div class="container">

    {% set periodo_texto = '' %}
    {% if filtros.data_inicio is defined and filtros.data_fim is defined %}
        {% set periodo_texto = filtros.data_inicio|date('d/m/Y') ~ ' a ' ~ filtros.data_fim|date('d/m/Y') %}
    {% endif %}

    {% include 'relatorios/pdf/_header.html.twig' with {
        titulo: 'Extrato de Conta Corrente',
        periodo: 'Período: ' ~ periodo_texto
    } %}

    {% if dados is not empty %}

    {# Bloco identificação do proprietário #}
    <div class="prop-block">
        <div class="prop-row bold">
            Proprietário: {{ dados.proprietario.cod }} - {{ dados.proprietario.nome }}
            {% if dados.proprietario.cnpj %}
                &nbsp;&nbsp;&nbsp; CNPJ: {{ dados.proprietario.cnpj }}
            {% elseif dados.proprietario.cpf %}
                &nbsp;&nbsp;&nbsp; CPF: {{ dados.proprietario.cpf }}
            {% endif %}
        </div>
    </div>

    {# Tabela principal: Histórico | Débito | Crédito #}
    <table>
        <thead>
            <tr>
                <th class="col-hist">Histórico</th>
                <th class="col-debito">Débito</th>
                <th class="col-credito">Crédito</th>
            </tr>
        </thead>
        <tbody>

            {# Saldo Anterior #}
            <tr class="row-saldo-ant">
                <td>Saldo Anterior</td>
                <td></td>
                <td class="text-right bold">{{ dados.saldo_anterior|number_format(2, ',', '.') }}</td>
            </tr>

            {# PAGAMENTOS #}
            <tr>
                <td colspan="3" class="row-section">PAGAMENTOS</td>
            </tr>
            {% for pag in dados.pagamentos %}
            <tr class="row-lancamento">
                <td>{{ pag.data|date('d/m') }} {{ pag.historico }}</td>
                <td class="text-right text-danger">{{ pag.valor|number_format(2, ',', '.') }}</td>
                <td></td>
            </tr>
            {% endfor %}
            <tr class="row-subtotal">
                <td colspan="2" class="text-right">SUBTOTAL:</td>
                <td class="text-right text-danger">-{{ dados.total_pagamentos|number_format(2, ',', '.') }}</td>
            </tr>

            {# MOVIMENTAÇÃO #}
            <tr>
                <td colspan="3" class="row-section">MOVIMENTAÇÃO</td>
            </tr>
            {% for grupo in dados.movimentacao %}
            <tr>
                <td colspan="3" class="row-imovel">
                    Imóvel: {{ grupo.imovel_cod }} - {{ grupo.imovel_endereco }}
                </td>
            </tr>
            <tr class="row-inquilino">
                <td colspan="3">
                    &nbsp;&nbsp;Inquilino(a): {{ grupo.inquilino_nome }}
                    {% if grupo.proximo_reajuste %}
                        &nbsp;&nbsp;&nbsp; Próx. Reaj.: {{ grupo.proximo_reajuste|date('d/m/Y') }}
                    {% endif %}
                </td>
            </tr>
            {% for lanc in grupo.lancamentos %}
            <tr class="row-lancamento">
                <td>{{ lanc.data|date('d/m') }} {{ lanc.historico }}</td>
                <td></td>
                <td class="text-right text-success">{{ lanc.valor|number_format(2, ',', '.') }}</td>
            </tr>
            {% endfor %}
            <tr class="row-subtotal">
                <td colspan="2" class="text-right">SUBTOTAL:</td>
                <td class="text-right text-success">{{ grupo.subtotal|number_format(2, ',', '.') }}</td>
            </tr>
            {% endfor %}

            {# Saldo Atual #}
            <tr class="row-saldo-atual">
                <td colspan="2" class="text-right">Saldo Atual:</td>
                <td class="text-right">{{ dados.saldo_atual|number_format(2, ',', '.') }}</td>
            </tr>

        </tbody>
    </table>

    {% else %}
    <p style="text-align:center; color:#999; margin-top:30px;">Nenhum dado encontrado para os filtros selecionados.</p>
    {% endif %}

    <div style="margin-top:20px; text-align:center; font-size:8px; color:#999; border-top:1px solid #ccc; padding-top:6px;">
        Emitido em: {{ data_emissao|date('d/m/Y H:i') }} — Sistema Almasa Imóveis
    </div>
</div>
</body>
</html>
