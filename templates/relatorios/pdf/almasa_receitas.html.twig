<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Receitas Almasa</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: DejaVu Sans, sans-serif; font-size: 10px; line-height: 1.4; color: #333; }
        .container { padding: 15px; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 10px; }
        th, td { border: 1px solid #ccc; padding: 4px 6px; text-align: left; font-size: 9px; }
        th { background: #333; color: #fff; font-weight: bold; }
        .text-right { text-align: right; }
        .text-center { text-align: center; }
        .text-danger { color: #dc3545; }
        .text-success { color: #198754; }
        .grupo-header { background: #555; color: #fff; font-weight: bold; }
        .grupo-subtotal { background: #f0f0f0; font-weight: bold; }
        .total-row { background: #eee; font-weight: bold; color: #198754; }
        .footer { margin-top: 20px; text-align: center; font-size: 8px; color: #666; border-top: 1px solid #ccc; padding-top: 8px; }
        .badge { display: inline-block; padding: 2px 6px; border-radius: 3px; font-size: 8px; font-weight: bold; }
        .badge-success { background: #198754; color: #fff; }
        .badge-warning { background: #ffc107; color: #000; }
        .badge-danger { background: #dc3545; color: #fff; }
    </style>
</head>
<body>
    <div class="container">
        {% set periodo_texto = '' %}
        {% if filtros.data_inicio is defined and filtros.data_fim is defined %}
            {% set periodo_texto = filtros.data_inicio|date('d/m/Y') ~ ' a ' ~ filtros.data_fim|date('d/m/Y') %}
        {% endif %}

        {% include 'relatorios/pdf/_header.html.twig' with {
            titulo: 'RECEITAS ALMASA EMPRESA',
            periodo: periodo_texto
        } %}

        {% if saldo_anterior is defined %}
        <table>
            <tr style="background: #d1ecf1;">
                <td style="border: 1px solid #bee5eb; padding: 6px;"><strong>Saldo Anterior:</strong></td>
                <td style="border: 1px solid #bee5eb; padding: 6px; text-align: right;" class="{% if saldo_anterior >= 0 %}text-success{% else %}text-danger{% endif %}">
                    <strong>R$ {{ saldo_anterior|number_format(2, ',', '.') }}</strong>
                </td>
            </tr>
        </table>
        {% endif %}

        <table>
            <thead>
                <tr>
                    <th>Data</th>
                    <th>Plano de Contas</th>
                    <th>Descrição</th>
                    <th class="text-right">Valor</th>
                    <th class="text-center">Status</th>
                </tr>
            </thead>
            <tbody>
                {% if dados is iterable and dados|length > 0 %}
                    {% set primeiro = dados|first %}
                    {% if primeiro.itens is defined %}
                        {% for grupo in dados %}
                            <tr class="grupo-header">
                                <td colspan="5">{{ grupo.nome }}</td>
                            </tr>
                            {% for item in grupo.itens %}
                                <tr>
                                    <td>{{ item.dataCompetencia|date('d/m/Y') }}</td>
                                    <td>{{ item.planoConta }}</td>
                                    <td>{{ item.descricao|length > 40 ? item.descricao|slice(0, 40) ~ '...' : item.descricao }}</td>
                                    <td class="text-right text-success">R$ {{ item.valor|number_format(2, ',', '.') }}</td>
                                    <td class="text-center">
                                        <span class="badge badge-{{ item.statusBadgeClass }}">{{ item.statusLabel }}</span>
                                    </td>
                                </tr>
                            {% endfor %}
                            <tr class="grupo-subtotal">
                                <td colspan="3" class="text-right">Subtotal ({{ grupo.itens|length }}):</td>
                                <td class="text-right">R$ {{ grupo.total|number_format(2, ',', '.') }}</td>
                                <td></td>
                            </tr>
                        {% endfor %}
                    {% else %}
                        {% for item in dados %}
                            <tr>
                                <td>{{ item.dataCompetencia|date('d/m/Y') }}</td>
                                <td>{{ item.planoConta }}</td>
                                <td>{{ item.descricao|length > 40 ? item.descricao|slice(0, 40) ~ '...' : item.descricao }}</td>
                                <td class="text-right text-success">R$ {{ item.valor|number_format(2, ',', '.') }}</td>
                                <td class="text-center">
                                    <span class="badge badge-{{ item.statusBadgeClass }}">{{ item.statusLabel }}</span>
                                </td>
                            </tr>
                        {% endfor %}
                    {% endif %}
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center">Nenhuma receita encontrada no periodo.</td>
                    </tr>
                {% endif %}
            </tbody>
            {% if totais is defined and totais.quantidade > 0 %}
            <tfoot>
                <tr class="total-row">
                    <td colspan="3" class="text-right">TOTAL ({{ totais.quantidade }} registros):</td>
                    <td class="text-right">R$ {{ totais.total_geral|number_format(2, ',', '.') }}</td>
                    <td></td>
                </tr>
                <tr>
                    <td colspan="2" class="text-right"><strong>Em Aberto:</strong></td>
                    <td class="text-right">R$ {{ totais.total_aberto|number_format(2, ',', '.') }}</td>
                    <td class="text-right"><strong>Recebido:</strong> R$ {{ totais.total_pago|number_format(2, ',', '.') }}</td>
                    <td></td>
                </tr>
            </tfoot>
            {% endif %}
        </table>

        {% if saldo_atual is defined %}
        <table>
            <tr style="background: #cfe2ff;">
                <td style="border: 1px solid #b6d4fe; padding: 6px;"><strong>Saldo Atual:</strong></td>
                <td style="border: 1px solid #b6d4fe; padding: 6px; text-align: right;" class="{% if saldo_atual >= 0 %}text-success{% else %}text-danger{% endif %}">
                    <strong>R$ {{ saldo_atual|number_format(2, ',', '.') }}</strong>
                </td>
            </tr>
        </table>
        {% endif %}

        {% include 'relatorios/pdf/_footer.html.twig' %}
    </div>
</body>
</html>
