{# Header padrao para PDFs — layout 3 colunas: logo | titulo | emissao #}
<table class="pdf-header-table" style="width:100%; border-collapse:collapse; margin-bottom:8px;">
    <tr>
        <td style="width:18%; vertical-align:middle; padding:0;">
            {% if logo_data_uri is defined and logo_data_uri %}
                <img src="{{ logo_data_uri }}" alt="Almasa" style="max-height:60px; max-width:110px;">
            {% else %}
                <strong style="font-size:13px;">ALMASA<br>Imóveis</strong>
            {% endif %}
        </td>
        <td style="text-align:center; vertical-align:middle; padding:0 10px;">
            <strong style="font-size:13px;">{{ titulo }}</strong>
            {% if periodo is defined and periodo %}
                <br><span style="font-size:11px;">{{ periodo }}</span>
            {% endif %}
            {% if subtitulo is defined and subtitulo %}
                <br><span style="font-size:10px; color:#555;">{{ subtitulo }}</span>
            {% endif %}
        </td>
        <td style="width:18%; text-align:right; vertical-align:top; font-size:9px; padding:0;">
            <em>Emitido em: {{ data_emissao is defined ? data_emissao|date('d/m/Y') : "now"|date('d/m/Y') }}</em>
        </td>
    </tr>
</table>
<hr style="border:1px solid #333; margin:4px 0 8px 0;">
