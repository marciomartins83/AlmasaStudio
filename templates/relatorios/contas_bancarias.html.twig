{% extends 'base.html.twig' %}

{% block title %}Relatório Contas Bancárias - {{ parent() }}{% endblock %}

{% block content %}
<div class="container-fluid">
    {% include '_partials/breadcrumb.html.twig' with {
        'items': [
            {'label': 'Dashboard', 'url': path('app_dashboard')},
            {'label': 'Relatórios', 'url': path('app_relatorios_index')}
        ],
        'current': 'Contas Bancárias'
    } %}

    <div class="row">
        {# Filtros #}
        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <i class="fas fa-filter"></i> Filtros
                </div>
                <div class="card-body">
                    <form id="formFiltros">
                        <div class="row mb-3">
                            <div class="col-6">
                                <label for="data_inicio" class="form-label">Data Inicio</label>
                                <input type="date" class="form-control" id="data_inicio" name="data_inicio"
                                       value="{{ "first day of this month"|date('Y-m-d') }}" required>
                            </div>
                            <div class="col-6">
                                <label for="data_fim" class="form-label">Data Fim</label>
                                <input type="date" class="form-control" id="data_fim" name="data_fim"
                                       value="{{ "now"|date('Y-m-d') }}" required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Conta Bancária</label>
                            <div class="pessoa-autocomplete-wrapper position-relative">
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                                    <input type="text" id="conta_bancaria_display" class="form-control"
                                           placeholder="Todas (buscar conta...)" autocomplete="off">
                                    <button type="button" class="btn btn-outline-secondary" id="conta_bancaria_clear" style="display:none">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </div>
                                <div id="conta_bancaria_results" class="list-group shadow" style="display:none; position:absolute; z-index:1000; width:100%; max-height:250px; overflow-y:auto;"></div>
                            </div>
                            <input type="hidden" id="id_conta_bancaria" name="id_conta_bancaria" value="">
                        </div>

                        <div class="mb-3">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="mostrar_movimentos" name="mostrar_movimentos">
                                <label class="form-check-label" for="mostrar_movimentos">
                                    Mostrar detalhes dos movimentos
                                </label>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="button" id="btnPreview" class="btn btn-primary">
                                <i class="fas fa-search"></i> Preview
                            </button>
                            <button type="button" id="btnPdf" class="btn btn-danger" disabled>
                                <i class="fas fa-file-pdf"></i> Gerar PDF
                            </button>
                            <a href="{{ path('app_relatorios_index') }}" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left"></i> Voltar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        {# Preview #}
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <i class="fas fa-eye"></i> Preview do Relatorio
                </div>
                <div class="card-body" id="previewContent">
                    <div class="text-center text-muted py-5">
                        <i class="fas fa-info-circle fa-3x mb-3"></i>
                        <p>Preencha os filtros e clique em "Preview" para visualizar o relatório.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    window.ROUTES = {
        preview: '{{ path('app_relatorios_contas_bancarias_preview') }}',
        pdf: '{{ path('app_relatorios_contas_bancarias_pdf') }}'
    };
    window.RELATORIO_TIPO = 'contas_bancarias';

    // Autocomplete conta bancária
    document.addEventListener('DOMContentLoaded', () => {
        const display = document.getElementById('conta_bancaria_display');
        const hidden = document.getElementById('id_conta_bancaria');
        const results = document.getElementById('conta_bancaria_results');
        const clear = document.getElementById('conta_bancaria_clear');
        const cbUrl = '{{ path("app_lancamentos_conta_bancaria_autocomplete") }}';
        if (!display || !hidden || !results) return;

        let timer = null;

        display.addEventListener('input', () => {
            const q = display.value.trim();
            hidden.value = '';
            if (clear) clear.style.display = 'none';
            clearTimeout(timer);
            if (q.length < 2) { results.style.display = 'none'; results.innerHTML = ''; return; }
            timer = setTimeout(async () => {
                try {
                    const resp = await fetch(cbUrl + '?q=' + encodeURIComponent(q));
                    if (!resp.ok) return;
                    const contas = await resp.json();
                    results.innerHTML = '';
                    if (!contas.length) {
                        results.innerHTML = '<div class="list-group-item text-muted fst-italic">Nenhuma conta encontrada</div>';
                        results.style.display = 'block';
                        return;
                    }
                    contas.forEach(c => {
                        const btn = document.createElement('button');
                        btn.type = 'button';
                        btn.className = 'list-group-item list-group-item-action';
                        const label = c.titular ? c.descricao + ' — ' + c.titular : (c.descricao || '');
                        btn.textContent = label;
                        btn.addEventListener('mousedown', (e) => {
                            e.preventDefault();
                            display.value = label;
                            hidden.value = c.id;
                            if (clear) clear.style.display = '';
                            results.style.display = 'none';
                            results.innerHTML = '';
                        });
                        results.appendChild(btn);
                    });
                    results.style.display = 'block';
                } catch (e) { console.error(e); }
            }, 300);
        });

        display.addEventListener('keydown', (e) => { if (e.key === 'Escape') { results.style.display = 'none'; results.innerHTML = ''; } });

        if (clear) {
            clear.addEventListener('click', () => {
                display.value = '';
                hidden.value = '';
                clear.style.display = 'none';
                display.focus();
            });
        }

        document.addEventListener('click', (e) => {
            if (!display.closest('.pessoa-autocomplete-wrapper')?.contains(e.target)) {
                results.style.display = 'none';
                results.innerHTML = '';
            }
        });
    });
</script>
{{ encore_entry_script_tags('relatorios') }}
{% endblock %}
