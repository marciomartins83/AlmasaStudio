{% extends 'base.html.twig' %}

{% block title %}Relatórios - {{ parent() }}{% endblock %}

{% block content %}
<div class="container-fluid">
    {% include '_partials/breadcrumb.html.twig' with {
        'items': [
            {'label': 'Dashboard', 'url': path('app_dashboard')}
        ],
        'current': 'Relatórios'
    } %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">
            <i class="fas fa-file-pdf text-danger"></i> Relatórios
        </h1>
    </div>

    {# ================================================================= #}
    {# SECAO: RELATORIOS DO CLIENTE                                      #}
    {# ================================================================= #}
    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="fas fa-users me-2"></i>Relatórios Cliente</h5>
            <small>Financeiro dos proprietarios, inquilinos e imoveis</small>
        </div>
        <div class="card-body">
            <div class="row g-4">
                {# Inadimplentes #}
                <div class="col-md-4 col-lg-3">
                    <div class="card h-100 border-danger">
                        <div class="card-body text-center">
                            <div class="mb-3">
                                <i class="fas fa-exclamation-triangle fa-3x text-danger"></i>
                            </div>
                            <h5 class="card-title">Inadimplentes</h5>
                            <p class="card-text text-muted">
                                Devedores com valores em atraso, juros e multa.
                            </p>
                            <a href="{{ path('app_relatorios_inadimplentes') }}" class="btn btn-danger">
                                <i class="fas fa-file-alt"></i> Gerar
                            </a>
                        </div>
                    </div>
                </div>

                {# Despesas Cliente #}
                <div class="col-md-4 col-lg-3">
                    <div class="card h-100 border-warning">
                        <div class="card-body text-center">
                            <div class="mb-3">
                                <i class="fas fa-arrow-circle-down fa-3x text-warning"></i>
                            </div>
                            <h5 class="card-title">Despesas</h5>
                            <p class="card-text text-muted">
                                Contas a pagar dos clientes por periodo.
                            </p>
                            <a href="{{ path('app_relatorios_despesas') }}" class="btn btn-warning">
                                <i class="fas fa-file-alt"></i> Gerar
                            </a>
                        </div>
                    </div>
                </div>

                {# Receitas Cliente #}
                <div class="col-md-4 col-lg-3">
                    <div class="card h-100 border-success">
                        <div class="card-body text-center">
                            <div class="mb-3">
                                <i class="fas fa-arrow-circle-up fa-3x text-success"></i>
                            </div>
                            <h5 class="card-title">Receitas</h5>
                            <p class="card-text text-muted">
                                Contas a receber dos clientes por periodo.
                            </p>
                            <a href="{{ path('app_relatorios_receitas') }}" class="btn btn-success">
                                <i class="fas fa-file-alt"></i> Gerar
                            </a>
                        </div>
                    </div>
                </div>

                {# Comparativo Cliente #}
                <div class="col-md-4 col-lg-3">
                    <div class="card h-100 border-primary">
                        <div class="card-body text-center">
                            <div class="mb-3">
                                <i class="fas fa-balance-scale fa-3x text-primary"></i>
                            </div>
                            <h5 class="card-title">Despesas x Receitas</h5>
                            <p class="card-text text-muted">
                                Comparativo com saldo final dos clientes.
                            </p>
                            <a href="{{ path('app_relatorios_despesas_receitas') }}" class="btn btn-primary">
                                <i class="fas fa-file-alt"></i> Gerar
                            </a>
                        </div>
                    </div>
                </div>

                {# Extrato Proprietario #}
                <div class="col-md-4 col-lg-3">
                    <div class="card h-100" style="border: 1px solid #6f42c1;">
                        <div class="card-body text-center">
                            <div class="mb-3">
                                <i class="fas fa-file-invoice-dollar fa-3x" style="color: #6f42c1;"></i>
                            </div>
                            <h5 class="card-title">Extrato Proprietário</h5>
                            <p class="card-text text-muted">
                                Saldo, pagamentos e movimentacao por imovel.
                            </p>
                            <a href="{{ path('app_relatorios_extrato_proprietario') }}" class="btn" style="background-color: #6f42c1; color: #fff;">
                                <i class="fas fa-file-alt"></i> Gerar
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ================================================================= #}
    {# SECAO: RELATORIOS ALMASA EMPRESA                                  #}
    {# ================================================================= #}
    <div class="card mb-4">
        <div class="card-header" style="background-color: #198754; color: #fff;">
            <h5 class="mb-0"><i class="fas fa-building me-2"></i>Relatórios Almasa Empresa</h5>
            <small>Financeiro da administradora (DRE, custos operacionais, receitas de taxas)</small>
        </div>
        <div class="card-body">
            <div class="row g-4">
                {# Despesas Almasa #}
                <div class="col-md-4 col-lg-3">
                    <div class="card h-100 border-danger">
                        <div class="card-body text-center">
                            <div class="mb-3">
                                <i class="fas fa-arrow-circle-down fa-3x text-danger"></i>
                            </div>
                            <h5 class="card-title">Despesas Almasa</h5>
                            <p class="card-text text-muted">
                                Custos operacionais, comissoes e despesas da empresa.
                            </p>
                            <a href="{{ path('app_relatorios_almasa_despesas') }}" class="btn btn-danger">
                                <i class="fas fa-file-alt"></i> Gerar
                            </a>
                        </div>
                    </div>
                </div>

                {# Receitas Almasa #}
                <div class="col-md-4 col-lg-3">
                    <div class="card h-100 border-success">
                        <div class="card-body text-center">
                            <div class="mb-3">
                                <i class="fas fa-arrow-circle-up fa-3x text-success"></i>
                            </div>
                            <h5 class="card-title">Receitas Almasa</h5>
                            <p class="card-text text-muted">
                                Taxas de administracao, honorarios e receitas da empresa.
                            </p>
                            <a href="{{ path('app_relatorios_almasa_receitas') }}" class="btn btn-success">
                                <i class="fas fa-file-alt"></i> Gerar
                            </a>
                        </div>
                    </div>
                </div>

                {# DRE Almasa #}
                <div class="col-md-4 col-lg-3">
                    <div class="card h-100" style="border: 2px solid #6f42c1;">
                        <div class="card-body text-center">
                            <div class="mb-3">
                                <i class="fas fa-chart-line fa-3x" style="color: #6f42c1;"></i>
                            </div>
                            <h5 class="card-title">Despesas x Receitas Almasa</h5>
                            <p class="card-text text-muted">
                                Comparativo / DRE da empresa Almasa.
                            </p>
                            <a href="{{ path('app_relatorios_almasa_despesas_receitas') }}" class="btn" style="background-color: #6f42c1; color: #fff;">
                                <i class="fas fa-file-alt"></i> Gerar
                            </a>
                        </div>
                    </div>
                </div>

                {# Plano de Contas Almasa #}
                <div class="col-md-4 col-lg-3">
                    <div class="card h-100 border-secondary">
                        <div class="card-body text-center">
                            <div class="mb-3">
                                <i class="fas fa-sitemap fa-3x text-secondary"></i>
                            </div>
                            <h5 class="card-title">Plano de Contas</h5>
                            <p class="card-text text-muted">
                                Relatório hierárquico por nível, grupo, tipo e status.
                            </p>
                            <a href="{{ path('app_relatorios_almasa_plano_contas') }}" class="btn btn-secondary">
                                <i class="fas fa-file-alt"></i> Gerar
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ================================================================= #}
    {# SECAO: RELATORIOS CADASTRAIS                                      #}
    {# ================================================================= #}
    <div class="card mb-4">
        <div class="card-header bg-secondary text-white">
            <h5 class="mb-0"><i class="fas fa-cog me-2"></i>Relatórios Cadastrais</h5>
            <small>Cadastros e configuracoes do sistema</small>
        </div>
        <div class="card-body">
            <div class="row g-4">
                {# Contas Bancarias #}
                <div class="col-md-4">
                    <div class="card h-100 border-info">
                        <div class="card-body text-center">
                            <div class="mb-3">
                                <i class="fas fa-university fa-3x text-info"></i>
                            </div>
                            <h5 class="card-title">Contas Bancárias</h5>
                            <p class="card-text text-muted">
                                Movimentacao e saldo de cada conta bancaria.
                            </p>
                            <a href="{{ path('app_relatorios_contas_bancarias') }}" class="btn btn-info">
                                <i class="fas fa-file-alt"></i> Gerar
                            </a>
                        </div>
                    </div>
                </div>

                {# Tipo de Lancamentos #}
                <div class="col-md-4">
                    <div class="card h-100 border-secondary">
                        <div class="card-body text-center">
                            <div class="mb-3">
                                <i class="fas fa-sitemap fa-3x text-secondary"></i>
                            </div>
                            <h5 class="card-title">Tipo de Lancamentos</h5>
                            <p class="card-text text-muted">
                                Estrutura hierarquica do plano de contas.
                            </p>
                            <a href="{{ path('app_relatorios_plano_contas') }}" class="btn btn-secondary">
                                <i class="fas fa-file-alt"></i> Gerar
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
