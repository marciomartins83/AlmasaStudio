{% extends 'base.html.twig' %}

{% block title %}Detalhes da Pessoa{% endblock %}

{% block content %}
<div class="container-fluid">
    {% include '_partials/breadcrumb.html.twig' with {
        'items': [
            {'label': 'Pessoas', 'url': path('app_pessoa_index')}
        ],
        'current': pessoa.nome
    } %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="fas fa-user"></i> {{ pessoa.nome }}</h1>
        <div>
            <a href="{{ path('app_financeiro_index', {'idInquilino': pessoa.idpessoa}) }}" class="btn btn-success" target="_blank">
                <i class="fas fa-dollar-sign"></i> Financeiro
            </a>
            <a href="{{ path('app_contrato_index') }}?pessoa={{ pessoa.idpessoa }}" class="btn btn-info" target="_blank">
                <i class="fas fa-file-contract"></i> Contratos
            </a>
            <a href="{{ path('app_boleto_index') }}?pessoa={{ pessoa.idpessoa }}" class="btn btn-primary" target="_blank">
                <i class="fas fa-barcode"></i> Boletos
            </a>
            <a href="{{ path('app_imovel_index') }}?pessoa={{ pessoa.idpessoa }}" class="btn btn-secondary" target="_blank">
                <i class="fas fa-building"></i> Imóveis
            </a>
            <a href="{{ path('app_pessoa_edit', {'id': pessoa.idpessoa}) }}" class="btn btn-warning">
                <i class="fas fa-edit"></i> Editar
            </a>
            <a href="{{ path('app_pessoa_index') }}" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Voltar
            </a>
        </div>
    </div>

    {# Dados Pessoais #}
    <div class="card mb-4">
        <div class="card-header">
            <h3><i class="fas fa-id-card"></i> Dados Pessoais</h3>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <table class="table table-borderless">
                        <tr>
                            <th style="width:40%">ID:</th>
                            <td>{{ pessoa.idpessoa }}</td>
                        </tr>
                        <tr>
                            <th>COD:</th>
                            <td>{{ pessoa.cod ?? '-' }}</td>
                        </tr>
                        <tr>
                            <th>Nome:</th>
                            <td>{{ pessoa.nome }}</td>
                        </tr>
                        <tr>
                            <th>Tipo Pessoa:</th>
                            <td>{{ pessoa.fisicaJuridica in ['F', 'fisica'] ? 'Pessoa Fisica' : 'Pessoa Juridica' }}</td>
                        </tr>
                        <tr>
                            <th>Data Nascimento:</th>
                            <td>{{ pessoa.dataNascimento ? pessoa.dataNascimento|date('d/m/Y') : '-' }}</td>
                        </tr>
                        <tr>
                            <th>Estado Civil:</th>
                            <td>{{ pessoa.estadoCivil ? pessoa.estadoCivil.nome : '-' }}</td>
                        </tr>
                        <tr>
                            <th>CPF/CNPJ:</th>
                            <td>
                                {% set cpfCnpj = null %}
                                {% for doc in pessoa.pessoasDocumentos %}
                                    {% if doc.tipoDocumento and doc.tipoDocumento.tipo in ['CPF', 'CNPJ'] %}
                                        {% set cpfCnpj = doc.numeroDocumento %}
                                    {% endif %}
                                {% endfor %}
                                {{ cpfCnpj ? cpfCnpj|format_documento : '-' }}
                            </td>
                        </tr>
                        <tr>
                            <th>Status:</th>
                            <td>
                                {% if pessoa.status %}
                                    <span class="badge bg-success">Ativo</span>
                                {% else %}
                                    <span class="badge bg-danger">Inativo</span>
                                {% endif %}
                            </td>
                        </tr>
                    </table>
                </div>
                <div class="col-md-6">
                    <table class="table table-borderless">
                        <tr>
                            <th style="width:40%">Nacionalidade:</th>
                            <td>{{ pessoa.nacionalidade ? pessoa.nacionalidade.nome : '-' }}</td>
                        </tr>
                        <tr>
                            <th>Naturalidade:</th>
                            <td>{{ pessoa.naturalidade ? pessoa.naturalidade.nome : '-' }}</td>
                        </tr>
                        <tr>
                            <th>Nome do Pai:</th>
                            <td>{{ pessoa.nomePai ?? '-' }}</td>
                        </tr>
                        <tr>
                            <th>Nome da Mae:</th>
                            <td>{{ pessoa.nomeMae ?? '-' }}</td>
                        </tr>
                        <tr>
                            <th>Renda:</th>
                            <td>{{ pessoa.renda ? ('R$ ' ~ pessoa.renda|number_format(2, ',', '.')) : '-' }}</td>
                        </tr>
                        <tr>
                            <th>Cadastro:</th>
                            <td>{{ pessoa.dtCadastro ? pessoa.dtCadastro|date('d/m/Y H:i') : '-' }}</td>
                        </tr>
                    </table>
                </div>
            </div>
            {% if pessoa.observacoes %}
            <div class="row">
                <div class="col-12">
                    <strong>Observacoes:</strong>
                    <p class="mt-1">{{ pessoa.observacoes }}</p>
                </div>
            </div>
            {% endif %}
        </div>
    </div>

    {# Documentos #}
    {% if pessoa.pessoasDocumentos|length > 0 %}
    <div class="card mb-4">
        <div class="card-header">
            <h3><i class="fas fa-file-alt"></i> Documentos</h3>
        </div>
        <div class="card-body">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Tipo</th>
                        <th>Número</th>
                        <th>Orgao Emissor</th>
                        <th>Data Emissao</th>
                        <th>Data Vencimento</th>
                    </tr>
                </thead>
                <tbody>
                    {% for doc in pessoa.pessoasDocumentos %}
                    <tr>
                        <td>{{ doc.tipoDocumento ? doc.tipoDocumento.tipo : '-' }}</td>
                        <td>{{ doc.numeroDocumento|format_documento }}</td>
                        <td>{{ doc.orgaoEmissor ?? '-' }}</td>
                        <td>{{ doc.dataEmissao ? doc.dataEmissao|date('d/m/Y') : '-' }}</td>
                        <td>{{ doc.dataVencimento ? doc.dataVencimento|date('d/m/Y') : '-' }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}

    {# Tipos de Pessoa #}
    {% if tipos|length > 0 %}
    <div class="card mb-4">
        <div class="card-header">
            <h3><i class="fas fa-tags"></i> Tipos de Pessoa</h3>
        </div>
        <div class="card-body">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Tipo</th>
                        <th>Data Inicio</th>
                        <th>Data Fim</th>
                        <th>Ativo</th>
                    </tr>
                </thead>
                <tbody>
                    {% for tipo in tipos %}
                    <tr>
                        <td>{{ tipo.tipo_nome ?? '-' }}</td>
                        <td>{{ tipo.data_inicio ? tipo.data_inicio|date('d/m/Y') : '-' }}</td>
                        <td>{{ tipo.data_fim ? tipo.data_fim|date('d/m/Y') : '-' }}</td>
                        <td>
                            {% if tipo.ativo %}
                                <span class="badge bg-success">Sim</span>
                            {% else %}
                                <span class="badge bg-danger">Nao</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}

    {# Profissoes #}
    {% if profissoes|length > 0 %}
    <div class="card mb-4">
        <div class="card-header">
            <h3><i class="fas fa-briefcase"></i> Profissoes</h3>
        </div>
        <div class="card-body">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Profissao</th>
                        <th>Empresa</th>
                        <th>Renda</th>
                        <th>Data Admissao</th>
                        <th>Data Demissao</th>
                    </tr>
                </thead>
                <tbody>
                    {% for profissao in profissoes %}
                    <tr>
                        <td>{{ profissao.profissao_nome ?? '-' }}</td>
                        <td>{{ profissao.empresa ?? '-' }}</td>
                        <td>{{ profissao.renda ? ('R$ ' ~ profissao.renda|number_format(2, ',', '.')) : '-' }}</td>
                        <td>{{ profissao.data_admissao ? profissao.data_admissao|date('d/m/Y') : '-' }}</td>
                        <td>{{ profissao.data_demissao ? profissao.data_demissao|date('d/m/Y') : '-' }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}

    {# Telefones #}
    {% if telefones|length > 0 %}
    <div class="card mb-4">
        <div class="card-header">
            <h3><i class="fas fa-phone"></i> Telefones</h3>
        </div>
        <div class="card-body">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Tipo</th>
                        <th>Número</th>
                    </tr>
                </thead>
                <tbody>
                    {% for tel in telefones %}
                    <tr>
                        <td>{{ tel.tipo_telefone ?? '-' }}</td>
                        <td>{{ tel.numero ?? '-' }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}

    {# Enderecos #}
    {% if enderecos|length > 0 %}
    <div class="card mb-4">
        <div class="card-header">
            <h3><i class="fas fa-map-marker-alt"></i> Enderecos</h3>
        </div>
        <div class="card-body">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Tipo</th>
                        <th>Logradouro</th>
                        <th>Número</th>
                        <th>Complemento</th>
                        <th>Bairro</th>
                        <th>Cidade/UF</th>
                        <th>CEP</th>
                    </tr>
                </thead>
                <tbody>
                    {% for end in enderecos %}
                    <tr>
                        <td>{{ end.tipo_endereco ?? '-' }}</td>
                        <td>{{ end.logradouro ?? '-' }}</td>
                        <td>{{ end.end_numero == 0 ? 'S/N' : end.end_numero }}</td>
                        <td>{{ end.complemento ?? '-' }}</td>
                        <td>{{ end.bairro ?? '-' }}</td>
                        <td>{{ end.cidade ?? '-' }}{% if end.uf %}/{{ end.uf }}{% endif %}</td>
                        <td>{{ end.cep ?? '-' }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}

    {# Emails #}
    {% if emails|length > 0 %}
    <div class="card mb-4">
        <div class="card-header">
            <h3><i class="fas fa-envelope"></i> Emails</h3>
        </div>
        <div class="card-body">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Tipo</th>
                        <th>Email</th>
                    </tr>
                </thead>
                <tbody>
                    {% for email in emails %}
                    <tr>
                        <td>{{ email.tipo_email ?? '-' }}</td>
                        <td><a href="mailto:{{ email.email }}">{{ email.email }}</a></td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}

    {# Chaves PIX #}
    {% if chavesPix|length > 0 %}
    <div class="card mb-4">
        <div class="card-header">
            <h3><i class="fas fa-key"></i> Chaves PIX</h3>
        </div>
        <div class="card-body">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Tipo Chave</th>
                        <th>Chave</th>
                        <th>Principal</th>
                        <th>Ativo</th>
                    </tr>
                </thead>
                <tbody>
                    {% for chave in chavesPix %}
                    <tr>
                        <td>{{ chave.tipo_chave_nome ?? '-' }}</td>
                        <td>{{ chave.chave_pix }}</td>
                        <td>
                            {% if chave.principal %}
                                <span class="badge bg-success">Sim</span>
                            {% else %}
                                <span class="badge bg-danger">Nao</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if chave.ativo %}
                                <span class="badge bg-success">Ativo</span>
                            {% else %}
                                <span class="badge bg-danger">Inativo</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}

    {# Contas Bancarias #}
    {% if contasBancarias|length > 0 %}
    <div class="card mb-4">
        <div class="card-header">
            <h3><i class="fas fa-bank"></i> Contas Bancárias</h3>
        </div>
        <div class="card-body">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Banco</th>
                        <th>Conta</th>
                        <th>Principal</th>
                        <th>Ativo</th>
                    </tr>
                </thead>
                <tbody>
                    {% for conta in contasBancarias %}
                    <tr>
                        <td>{{ conta.banco_nome ?? '-' }}</td>
                        <td>{{ conta.codigo }}{% if conta.digito_conta %}-{{ conta.digito_conta }}{% endif %}</td>
                        <td>
                            {% if conta.principal %}
                                <span class="badge bg-success">Sim</span>
                            {% else %}
                                <span class="badge bg-danger">Nao</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if conta.ativo %}
                                <span class="badge bg-success">Ativo</span>
                            {% else %}
                                <span class="badge bg-danger">Inativo</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}

</div>
{% endblock %}
