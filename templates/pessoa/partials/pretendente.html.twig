<div class="card mb-4">
    <div class="card-header">
        <h3><i class="fas fa-search-location"></i> Dados do Pretendente</h3>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-4">{{ form_row(form.tipoImovel) }}</div>
            <div class="col-md-4">{{ form_row(form.quartosDesejados) }}</div>
            <div class="col-md-4">
                {% include '_partials/autocomplete_field.html.twig' with {
                    id: 'pretendente_logradouroDesejado',
                    name: form.logradouroDesejado.vars.full_name,
                    label: 'Logradouro Desejado',
                    url: path('app_autocomplete_logradouros'),
                    value: form.logradouroDesejado.vars.value|default(''),
                    display: preloads.logradouroDesejado|default(''),
                    placeholder: 'Digite para buscar logradouro...'
                } %}
            </div>
        </div>
        <div class="row">
            <div class="col-md-4">{{ form_row(form.aluguelMaximo) }}</div>
            <div class="col-md-4">{{ form_row(form.atendente) }}</div>
            <div class="col-md-4">{{ form_row(form.tipoAtendimento) }}</div>
        </div>
        <div class="row">
            <div class="col-md-4">{{ form_row(form.dataCadastro) }}</div>
        </div>
        <hr>
        <div class="row">
            <div class="col-md-4">{{ form_row(form.disponivel) }}</div>
            <div class="col-md-4">{{ form_row(form.procuraAluguel) }}</div>
            <div class="col-md-4">{{ form_row(form.procuraCompra) }}</div>
        </div>
        {{ form_row(form.observacoes) }}
    </div>
</div>