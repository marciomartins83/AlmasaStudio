{% extends 'base.html.twig' %}

{% block title %}Plano de Contas Almasa - {{ parent() }}{% endblock %}

{% block content %}
<div class="container-fluid">
    {% include '_partials/breadcrumb.html.twig' with {
        'items': [
            {'label': 'Financeiro', 'url': '#'}
        ],
        'current': 'Plano de Contas Almasa'
    } %}
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h1><i class="fas fa-sitemap"></i> Plano de Contas Almasa</h1>
                <a href="{{ path('app_almasa_plano_contas_new') }}" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Nova Conta
                </a>
            </div>

            {# Painel de Busca #}
            {% include '_partials/search_panel.html.twig' with {
                filterDefs: pagination.filterDefs,
                filters: pagination.filters,
                routeName: 'app_almasa_plano_contas_index',
                itemsPerPage: pagination.itemsPerPage,
                sortField: pagination.sortField,
                sortDir: pagination.sortDir
            } %}

            {# Painel de Ordenacao #}
            {% include '_partials/sort_panel.html.twig' with {
                sortOptions: pagination.sortOptions,
                sortField: pagination.sortField,
                sortDir: pagination.sortDir,
                routeName: 'app_almasa_plano_contas_index',
                filters: pagination.filters,
                itemsPerPage: pagination.itemsPerPage
            } %}

            <div class="card">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th width="80">ID</th>
                                    <th width="120">Codigo</th>
                                    <th>Descricao</th>
                                    <th width="100">Tipo</th>
                                    <th width="100">Nivel</th>
                                    <th width="100" class="text-center">Aceita Lanc.</th>
                                    <th width="80" class="text-center">Ativo</th>
                                    <th width="200">Acoes</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for conta in pagination.items %}
                                <tr>
                                    <td>{{ conta.id }}</td>
                                    <td>
                                        <code>
                                            {% set indent = '&nbsp;&nbsp;'|repeat(conta.nivel - 1) %}
                                            {% if conta.nivel <= 2 %}
                                                <strong>{{ indent|raw }}{{ conta.codigo }}</strong>
                                            {% else %}
                                                {{ indent|raw }}{{ conta.codigo }}
                                            {% endif %}
                                        </code>
                                    </td>
                                    <td>
                                        {% set indent = '&nbsp;&nbsp;'|repeat(conta.nivel - 1) %}
                                        {% if conta.nivel == 1 %}
                                            <strong class="text-dark">{{ conta.descricao }}</strong>
                                        {% elseif conta.nivel == 2 %}
                                            <strong class="text-secondary">{{ indent|raw }}{{ conta.descricao }}</strong>
                                        {% else %}
                                            <span class="text-{{ conta.nivel >= 4 ? 'body' : 'secondary' }}">{{ indent|raw }}{{ conta.descricao }}</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% set tipoBadge = {
                                            'ativo': 'primary',
                                            'passivo': 'warning',
                                            'patrimonio_liquido': 'info',
                                            'receita': 'success',
                                            'despesa': 'danger'
                                        } %}
                                        <span class="badge bg-{{ tipoBadge[conta.tipo] ?? 'secondary' }}">{{ conta.tipoLabel }}</span>
                                    </td>
                                    <td>
                                        {% set nivelBadge = { 1: 'dark', 2: 'secondary', 3: 'info', 4: 'primary', 5: 'light text-dark' } %}
                                        <span class="badge bg-{{ nivelBadge[conta.nivel] ?? 'secondary' }}">
                                            {{ conta.nivelLabel }}
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        {% if conta.isAceitaLancamentos() %}
                                            <i class="fas fa-check-circle text-success"></i>
                                        {% else %}
                                            <i class="fas fa-minus-circle text-muted"></i>
                                        {% endif %}
                                    </td>
                                    <td class="text-center">
                                        {% if conta.isAtivo() %}
                                            <i class="fas fa-check-circle text-success"></i>
                                        {% else %}
                                            <i class="fas fa-times-circle text-danger"></i>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <div class="btn-group d-none d-md-flex" role="group">
                                            <a href="{{ path('app_almasa_plano_contas_show', {'id': conta.id}) }}"
                                               class="btn btn-info btn-sm">
                                                <i class="fas fa-eye"></i> Ver
                                            </a>
                                            <a href="{{ path('app_almasa_plano_contas_edit', {'id': conta.id}) }}"
                                               class="btn btn-warning btn-sm">
                                                <i class="fas fa-edit"></i> Editar
                                            </a>
                                            {% if conta.filhos is empty %}
                                            <form method="post"
                                                  action="{{ path('app_almasa_plano_contas_delete', {'id': conta.id}) }}"
                                                  style="display:inline-block"
                                                  data-confirm-delete="Tem certeza que deseja excluir esta conta?">
                                                <input type="hidden" name="_token"
                                                       value="{{ csrf_token('delete' ~ conta.id) }}">
                                                <button class="btn btn-danger btn-sm">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                            {% endif %}
                                        </div>
                                    </td>
                                </tr>
                                {% else %}
                                <tr>
                                    <td colspan="8" class="text-center text-muted py-4">
                                        <i class="fas fa-info-circle fa-2x mb-2 d-block"></i>
                                        Nenhuma conta encontrada
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            {# Paginacao #}
            {% include '_partials/pagination.html.twig' with {
                totalItems: pagination.totalItems,
                currentPage: pagination.currentPage,
                itemsPerPage: pagination.itemsPerPage,
                totalPages: pagination.totalPages,
                routeName: 'app_almasa_plano_contas_index',
                filters: pagination.filters,
                sortField: pagination.sortField,
                sortDir: pagination.sortDir,
                showSearch: false
            } %}
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
{{ encore_entry_script_tags('crud_filters') }}
{% endblock %}
