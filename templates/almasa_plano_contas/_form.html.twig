{{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': true, 'id': 'almasa-pc-form'}}) }}

{# === PASSO 1: Nivel Hierarquico === #}
<div class="card mb-3 border-primary">
    <div class="card-header bg-primary text-white py-2">
        <i class="fas fa-layer-group"></i> <strong>Passo 1</strong> — O que deseja {{ is_edit|default(false) ? 'editar' : 'criar' }}?
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-4">
                {{ form_row(form.nivel) }}
            </div>
            <div class="col-md-8">
                <div id="nivel-help" class="alert alert-light border mb-0 mt-4">
                    <i class="fas fa-info-circle text-primary"></i>
                    <span id="nivel-help-text">Selecione o nivel para ver a descricao.</span>
                </div>
            </div>
        </div>
    </div>
</div>

{# === PASSO 2: Vinculacao (aparece apos selecionar nivel) === #}
<div class="card mb-3" id="card-vinculacao" style="display:none">
    <div class="card-header bg-light py-2">
        <i class="fas fa-sitemap"></i> <strong>Passo 2</strong> — Vinculacao
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6" id="pai-wrapper">
                <label class="form-label">Pertence a</label>
                {{ form_widget(form.pai) }}
                <div class="autocomplete-wrapper" data-url="{{ path('app_autocomplete_almasa_plano_contas') }}" data-hidden="#{{ form.pai.vars.id }}" data-min="1"{% if preloads.pai is defined and preloads.pai %} data-preload-label="{{ preloads.pai }}"{% endif %}>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                        <input type="text" class="form-control autocomplete-display" placeholder="Digite para buscar..." id="pai-autocomplete-display">
                    </div>
                    <div class="autocomplete-results list-group" style="display:none; position:absolute; z-index:1050; width:100%;"></div>
                </div>
                <small class="text-muted" id="pai-help"></small>
            </div>
            <div class="col-md-3" id="tipo-wrapper">
                {{ form_row(form.tipo) }}
                <small class="text-muted" id="tipo-help"></small>
            </div>
        </div>
    </div>
</div>

{# === PASSO 3: Identificacao (aparece apos selecionar nivel) === #}
<div class="card mb-3" id="card-identificacao" style="display:none">
    <div class="card-header bg-light py-2">
        <i class="fas fa-tag"></i> <strong>Passo 3</strong> — Identificacao
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-4">
                {# Modo simples — para Classe (nivel 1) ou sem pai #}
                <div id="codigo-modo-simples">
                    {{ form_row(form.codigo) }}
                </div>
                {# Modo composto — prefixo travado + sufixo editavel #}
                <div id="codigo-modo-composto" style="display:none">
                    <label class="form-label">Codigo</label>
                    <div class="input-group">
                        <span class="input-group-text fw-bold bg-light" id="codigo-prefixo-display"></span>
                        <input type="text" class="form-control fw-bold" id="codigo-sufixo-input" placeholder="001">
                    </div>
                    <small class="text-success" id="codigo-sugestao"></small>
                </div>
                {{ form_errors(form.codigo) }}
                <small class="text-muted" id="codigo-help"></small>
            </div>
            <div class="col-md-8">
                {{ form_row(form.descricao) }}
            </div>
        </div>
    </div>
</div>

{# === PASSO 4: Opcoes (aparece apos selecionar nivel) === #}
<div class="card mb-3" id="card-opcoes" style="display:none">
    <div class="card-header bg-light py-2">
        <i class="fas fa-cog"></i> Opcoes
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-3" id="aceita-wrapper">
                <div class="form-check mt-1">
                    {{ form_widget(form.aceitaLancamentos) }}
                    {{ form_label(form.aceitaLancamentos) }}
                </div>
                <small class="text-muted" id="aceita-help"></small>
            </div>
            <div class="col-md-3">
                {{ form_row(form.saldoAnterior) }}
            </div>
            <div class="col-md-3">
                <div class="form-check mt-1">
                    {{ form_widget(form.ativo) }}
                    {{ form_label(form.ativo) }}
                </div>
            </div>
        </div>
    </div>
</div>

{# === Botoes === #}
<div class="d-flex justify-content-between mt-3">
    <a href="{{ path('app_almasa_plano_contas_index') }}" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Voltar
    </a>
    <div>
        {% if is_edit|default(false) %}
        <a href="{{ path('app_almasa_plano_contas_show', {'id': conta.id}) }}" class="btn btn-info me-2">
            <i class="fas fa-eye"></i> Visualizar
        </a>
        {% endif %}
        <button type="submit" class="btn btn-success" id="btn-salvar">
            <i class="fas fa-save"></i> {{ is_edit|default(false) ? 'Salvar Alteracoes' : 'Salvar' }}
        </button>
    </div>
</div>

{{ form_end(form) }}

<script src="{{ asset('js/generic_autocomplete.js') }}"></script>
<script>
(function() {
    var API_URL = '{{ path("app_almasa_plano_contas_api_proximo_codigo", {paiId: "__ID__"}) }}';
    var AUTOCOMPLETE_URL = '{{ path("app_autocomplete_almasa_plano_contas") }}';

    var nivelSelect = document.getElementById('{{ form.nivel.vars.id }}');
    var paiHidden = document.getElementById('{{ form.pai.vars.id }}');
    var tipoSelect = document.getElementById('{{ form.tipo.vars.id }}');
    var codigoInput = document.getElementById('{{ form.codigo.vars.id }}');
    var aceitaCheckbox = document.getElementById('{{ form.aceitaLancamentos.vars.id }}');

    var paiWrapper = document.getElementById('pai-wrapper');
    var paiAutocompleteWrapper = paiWrapper.querySelector('.autocomplete-wrapper');
    var paiDisplay = document.getElementById('pai-autocomplete-display');

    var cardVinculacao = document.getElementById('card-vinculacao');
    var cardIdentificacao = document.getElementById('card-identificacao');
    var cardOpcoes = document.getElementById('card-opcoes');
    var aceitaWrapper = document.getElementById('aceita-wrapper');
    var nivelHelp = document.getElementById('nivel-help-text');
    var paiHelp = document.getElementById('pai-help');
    var tipoHelp = document.getElementById('tipo-help');
    var codigoHelp = document.getElementById('codigo-help');
    var aceitaHelp = document.getElementById('aceita-help');

    // Codigo composto
    var codigoSimples = document.getElementById('codigo-modo-simples');
    var codigoComposto = document.getElementById('codigo-modo-composto');
    var prefixoDisplay = document.getElementById('codigo-prefixo-display');
    var sufixoInput = document.getElementById('codigo-sufixo-input');
    var codigoSugestao = document.getElementById('codigo-sugestao');

    var currentPrefixo = '';
    var IS_EDIT = {{ is_edit|default(false) ? 'true' : 'false' }};
    var CURRENT_CODIGO = '{{ is_edit|default(false) ? conta.codigo : '' }}';
    var isInitialLoad = IS_EDIT;

    // Store selected pai's tipo for inheritance
    var selectedPaiTipo = null;

    var NIVEL_TEXTS = {
        '1': {
            help: 'Classe e o nivel raiz do plano de contas. Exemplos: Ativo, Passivo, Receita, Despesa.',
            paiHelp: '',
            tipoHelp: 'Defina o tipo contabil desta classe.',
            codigoHelp: 'Informe o numero da classe (ex: 1, 2, 3)',
            aceitaHelp: 'Classes nao recebem lancamentos.',
            label: 'Classe'
        },
        '2': {
            help: 'Grupo e uma subdivisao dentro de uma Classe. Ex: dentro de "Receita", criar grupo "Receitas Operacionais".',
            paiHelp: 'Selecione a Classe onde este grupo sera criado.',
            tipoHelp: 'Herdado da classe pai.',
            codigoHelp: '',
            aceitaHelp: 'Grupos nao recebem lancamentos.',
            label: 'Grupo',
            paiNivel: 1
        },
        '3': {
            help: 'Subgrupo e uma subdivisao dentro de um Grupo. Ex: dentro de "Receitas Operacionais", criar "Taxas de Administracao".',
            paiHelp: 'Selecione o Grupo onde este subgrupo sera criado.',
            tipoHelp: 'Herdado do grupo pai.',
            codigoHelp: '',
            aceitaHelp: 'Subgrupos nao recebem lancamentos.',
            label: 'Subgrupo',
            paiNivel: 2
        },
        '4': {
            help: 'Conta e o nivel operacional — e aqui que os lancamentos sao registrados. Ex: "Taxa Adm. Locacao", "Energia Eletrica".',
            paiHelp: 'Selecione o Subgrupo onde esta conta sera criada.',
            tipoHelp: 'Herdado do subgrupo pai.',
            codigoHelp: '',
            aceitaHelp: 'Contas recebem lancamentos financeiros.',
            label: 'Conta',
            paiNivel: 3
        }
    };

    // Custom autocomplete for pai that filters by nivel and captures tipo
    function initPaiAutocomplete() {
        var display = paiDisplay;
        var results = paiAutocompleteWrapper.querySelector('.autocomplete-results');
        var hidden = paiHidden;
        var minLen = 1;
        var timer = null;
        var activeIndex = -1;

        display.addEventListener('input', function () {
            var q = display.value.trim();
            hidden.value = '';
            selectedPaiTipo = null;
            clearTimeout(timer);
            if (q.length < minLen) { fecharPai(); return; }
            timer = setTimeout(function () { buscarPai(q); }, 300);
        });

        display.addEventListener('keydown', function (e) {
            var items = results.querySelectorAll('.list-group-item-action');
            if (!items.length) return;
            if (e.key === 'ArrowDown') { e.preventDefault(); activeIndex = Math.min(activeIndex + 1, items.length - 1); marcarPai(items); }
            else if (e.key === 'ArrowUp') { e.preventDefault(); activeIndex = Math.max(activeIndex - 1, 0); marcarPai(items); }
            else if (e.key === 'Enter') { e.preventDefault(); if (activeIndex >= 0 && items[activeIndex]) items[activeIndex].click(); }
            else if (e.key === 'Escape') { fecharPai(); }
        });

        document.addEventListener('click', function (e) {
            if (!paiAutocompleteWrapper.contains(e.target)) fecharPai();
        });

        function buscarPai(q) {
            var nivel = nivelSelect.value;
            var config = NIVEL_TEXTS[nivel];
            if (!config || !config.paiNivel) return;

            var url = AUTOCOMPLETE_URL + '?q=' + encodeURIComponent(q) + '&nivel=' + config.paiNivel;
            fetch(url)
                .then(function (r) { return r.ok ? r.json() : []; })
                .then(function (data) { renderizarPai(data); })
                .catch(function () { fecharPai(); });
        }

        function renderizarPai(items) {
            results.innerHTML = '';
            activeIndex = -1;
            if (!items.length) {
                results.innerHTML = '<div class="list-group-item text-muted fst-italic">Nenhum resultado</div>';
                results.style.display = 'block';
                return;
            }
            items.forEach(function (item) {
                var btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'list-group-item list-group-item-action';
                btn.textContent = item.label || item.nome || '';
                btn.addEventListener('mousedown', function (e) {
                    e.preventDefault();
                    display.value = btn.textContent;
                    hidden.value = item.id || '';
                    selectedPaiTipo = item.tipo || null;
                    fecharPai();
                    onPaiChange();
                });
                results.appendChild(btn);
            });
            results.style.display = 'block';
        }

        function fecharPai() { results.style.display = 'none'; results.innerHTML = ''; activeIndex = -1; }
        function marcarPai(items) {
            items.forEach(function (el, i) { el.classList.toggle('active', i === activeIndex); });
            if (items[activeIndex]) items[activeIndex].scrollIntoView({ block: 'nearest' });
        }

        // Preload
        if (paiAutocompleteWrapper.dataset.preloadLabel) {
            display.value = paiAutocompleteWrapper.dataset.preloadLabel;
        }
    }

    function onNivelChange() {
        var nivel = nivelSelect.value;
        if (!nivel) {
            cardVinculacao.style.display = 'none';
            cardIdentificacao.style.display = 'none';
            cardOpcoes.style.display = 'none';
            nivelHelp.textContent = 'Selecione o nivel para ver a descricao.';
            return;
        }

        var config = NIVEL_TEXTS[nivel];

        // Mostrar cards
        cardVinculacao.style.display = '';
        cardIdentificacao.style.display = '';
        cardOpcoes.style.display = '';

        // Atualizar textos de ajuda
        nivelHelp.innerHTML = '<strong>' + config.label + ':</strong> ' + config.help;
        paiHelp.textContent = config.paiHelp;
        tipoHelp.textContent = config.tipoHelp;
        codigoHelp.textContent = config.codigoHelp;
        aceitaHelp.textContent = config.aceitaHelp;

        // Classe (1): sem pai, tipo manual, codigo livre
        if (nivel === '1') {
            paiWrapper.style.display = 'none';
            paiHidden.value = '';
            paiDisplay.value = '';
            selectedPaiTipo = null;
            tipoSelect.disabled = false;
            tipoHelp.textContent = config.tipoHelp;
            mostrarCodigoSimples();
            codigoInput.setAttribute('placeholder', 'Ex: 1');
        } else {
            paiWrapper.style.display = '';
            // Clear pai when changing nivel (unless initial load)
            if (!isInitialLoad) {
                paiHidden.value = '';
                paiDisplay.value = '';
                selectedPaiTipo = null;
                tipoSelect.disabled = false;
                mostrarCodigoSimples();
            }
        }

        // AceitaLancamentos: so para Conta (4)
        if (nivel === '4') {
            aceitaWrapper.style.display = '';
            aceitaCheckbox.checked = true;
            aceitaCheckbox.disabled = false;
        } else {
            aceitaWrapper.style.display = 'none';
            aceitaCheckbox.checked = false;
        }
    }

    function onPaiChange() {
        var nivel = nivelSelect.value;
        if (nivel === '1') return;

        if (paiHidden.value) {
            // Herdar tipo do pai
            if (selectedPaiTipo) {
                tipoSelect.value = selectedPaiTipo;
                tipoSelect.disabled = true;
            }
            // Buscar proximo codigo via API
            fetchProximoCodigo(paiHidden.value);
        } else {
            tipoSelect.disabled = false;
            mostrarCodigoSimples();
        }
    }

    function fetchProximoCodigo(paiId) {
        var url = API_URL.replace('__ID__', paiId);
        fetch(url)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.error) return;
                currentPrefixo = data.prefixo;
                mostrarCodigoComposto(data.prefixo, data.sufixo, data.padLen);
            })
            .catch(function() {
                mostrarCodigoSimples();
            });
    }

    function mostrarCodigoSimples() {
        codigoSimples.style.display = '';
        codigoComposto.style.display = 'none';
        currentPrefixo = '';
        codigoSugestao.textContent = '';
    }

    function mostrarCodigoComposto(prefixo, sufixo, padLen) {
        codigoSimples.style.display = 'none';
        codigoComposto.style.display = '';

        prefixoDisplay.textContent = prefixo;
        sufixoInput.setAttribute('maxlength', String(padLen + 1));
        sufixoInput.setAttribute('placeholder', sufixo);
        codigoSugestao.innerHTML = '<i class="fas fa-magic"></i> Proximo disponivel: <strong>' + prefixo + sufixo + '</strong>';

        // Em modo edicao na carga inicial: preservar o codigo atual, nao sobrescrever
        if (isInitialLoad && CURRENT_CODIGO && CURRENT_CODIGO.startsWith(prefixo)) {
            var editSufixo = CURRENT_CODIGO.substring(prefixo.length);
            sufixoInput.value = editSufixo;
            codigoInput.value = CURRENT_CODIGO;
            isInitialLoad = false;
        } else {
            sufixoInput.value = sufixo;
            codigoInput.value = prefixo + sufixo;
        }

        codigoInput.style.display = 'none';
    }

    // Sincronizar sufixo editavel com campo hidden do Symfony
    sufixoInput.addEventListener('input', function() {
        codigoInput.value = currentPrefixo + sufixoInput.value;
    });

    // Event listeners
    nivelSelect.addEventListener('change', function() {
        isInitialLoad = false;
        onNivelChange();
    });

    // Re-habilitar tipo antes do submit
    document.getElementById('almasa-pc-form').addEventListener('submit', function() {
        tipoSelect.disabled = false;
        // Garantir que o codigo esta atualizado
        if (currentPrefixo && sufixoInput.value) {
            codigoInput.value = currentPrefixo + sufixoInput.value;
        }
        codigoInput.style.display = '';
    });

    // Initialize custom pai autocomplete
    initPaiAutocomplete();

    // Inicializar (para edicao onde ja tem valor)
    if (nivelSelect.value) {
        onNivelChange();
        var nivel = nivelSelect.value;
        if (nivel !== '1' && paiHidden.value) {
            // Need to fetch the pai's tipo for inheritance
            fetch(AUTOCOMPLETE_URL + '?q=' + encodeURIComponent(paiDisplay.value.substring(0, 5)) + '&nivel=' + NIVEL_TEXTS[nivel].paiNivel)
                .then(function(r) { return r.ok ? r.json() : []; })
                .then(function(data) {
                    data.forEach(function(item) {
                        if (String(item.id) === String(paiHidden.value)) {
                            selectedPaiTipo = item.tipo;
                            onPaiChange();
                        }
                    });
                });
        }
    }
})();
</script>
