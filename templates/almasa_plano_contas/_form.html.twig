{{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': true, 'id': 'almasa-pc-form'}}) }}

{# === PASSO 1: Nivel Hierarquico === #}
<div class="card mb-3 border-primary">
    <div class="card-header bg-primary text-white py-2">
        <i class="fas fa-layer-group"></i> <strong>Passo 1</strong> — O que deseja {{ is_edit|default(false) ? 'editar' : 'criar' }}?
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-4">
                {{ form_row(form.nivel) }}
            </div>
            <div class="col-md-8">
                <div id="nivel-help" class="alert alert-light border mb-0 mt-4">
                    <i class="fas fa-info-circle text-primary"></i>
                    <span id="nivel-help-text">Selecione o nivel para ver a descricao.</span>
                </div>
            </div>
        </div>
    </div>
</div>

{# === PASSO 2: Vinculacao (aparece apos selecionar nivel) === #}
<div class="card mb-3" id="card-vinculacao" style="display:none">
    <div class="card-header bg-light py-2">
        <i class="fas fa-sitemap"></i> <strong>Passo 2</strong> — Vinculacao
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6" id="pai-wrapper">
                {{ form_row(form.pai) }}
                <small class="text-muted" id="pai-help"></small>
            </div>
            <div class="col-md-3" id="tipo-wrapper">
                {{ form_row(form.tipo) }}
                <small class="text-muted" id="tipo-help"></small>
            </div>
        </div>
    </div>
</div>

{# === PASSO 3: Identificacao (aparece apos selecionar nivel) === #}
<div class="card mb-3" id="card-identificacao" style="display:none">
    <div class="card-header bg-light py-2">
        <i class="fas fa-tag"></i> <strong>Passo 3</strong> — Identificacao
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-4">
                {# Modo simples — para Classe (nivel 1) ou sem pai #}
                <div id="codigo-modo-simples">
                    {{ form_row(form.codigo) }}
                </div>
                {# Modo composto — prefixo travado + sufixo editavel #}
                <div id="codigo-modo-composto" style="display:none">
                    <label class="form-label">Código</label>
                    <div class="input-group">
                        <span class="input-group-text fw-bold bg-light" id="codigo-prefixo-display"></span>
                        <input type="text" class="form-control fw-bold" id="codigo-sufixo-input" placeholder="001">
                    </div>
                    <small class="text-success" id="codigo-sugestao"></small>
                </div>
                {{ form_errors(form.codigo) }}
                <small class="text-muted" id="codigo-help"></small>
            </div>
            <div class="col-md-8">
                {{ form_row(form.descricao) }}
            </div>
        </div>
    </div>
</div>

{# === PASSO 4: Opcoes (aparece apos selecionar nivel) === #}
<div class="card mb-3" id="card-opcoes" style="display:none">
    <div class="card-header bg-light py-2">
        <i class="fas fa-cog"></i> Opcoes
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-3" id="aceita-wrapper">
                <div class="form-check mt-1">
                    {{ form_widget(form.aceitaLancamentos) }}
                    {{ form_label(form.aceitaLancamentos) }}
                </div>
                <small class="text-muted" id="aceita-help"></small>
            </div>
            <div class="col-md-3">
                <div class="form-check mt-1">
                    {{ form_widget(form.ativo) }}
                    {{ form_label(form.ativo) }}
                </div>
            </div>
        </div>
    </div>
</div>

{# === Botoes === #}
<div class="d-flex justify-content-between mt-3">
    <a href="{{ path('app_almasa_plano_contas_index') }}" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Voltar
    </a>
    <div>
        {% if is_edit|default(false) %}
        <a href="{{ path('app_almasa_plano_contas_show', {'id': conta.id}) }}" class="btn btn-info me-2">
            <i class="fas fa-eye"></i> Visualizar
        </a>
        {% endif %}
        <button type="submit" class="btn btn-success" id="btn-salvar">
            <i class="fas fa-save"></i> {{ is_edit|default(false) ? 'Salvar Alteracoes' : 'Salvar' }}
        </button>
    </div>
</div>

{{ form_end(form) }}

<script>
(function() {
    const API_URL = '{{ path("app_almasa_plano_contas_api_proximo_codigo", {paiId: "__ID__"}) }}';

    const nivelSelect = document.getElementById('{{ form.nivel.vars.id }}');
    const paiSelect = document.getElementById('{{ form.pai.vars.id }}');
    const tipoSelect = document.getElementById('{{ form.tipo.vars.id }}');
    const codigoInput = document.getElementById('{{ form.codigo.vars.id }}');
    const aceitaCheckbox = document.getElementById('{{ form.aceitaLancamentos.vars.id }}');

    const cardVinculacao = document.getElementById('card-vinculacao');
    const cardIdentificacao = document.getElementById('card-identificacao');
    const cardOpcoes = document.getElementById('card-opcoes');
    const paiWrapper = document.getElementById('pai-wrapper');
    const aceitaWrapper = document.getElementById('aceita-wrapper');
    const nivelHelp = document.getElementById('nivel-help-text');
    const paiHelp = document.getElementById('pai-help');
    const tipoHelp = document.getElementById('tipo-help');
    const codigoHelp = document.getElementById('codigo-help');
    const aceitaHelp = document.getElementById('aceita-help');

    // Codigo composto
    const codigoSimples = document.getElementById('codigo-modo-simples');
    const codigoComposto = document.getElementById('codigo-modo-composto');
    const prefixoDisplay = document.getElementById('codigo-prefixo-display');
    const sufixoInput = document.getElementById('codigo-sufixo-input');
    const codigoSugestao = document.getElementById('codigo-sugestao');

    let currentPrefixo = '';
    const IS_EDIT = {{ is_edit|default(false) ? 'true' : 'false' }};
    const CURRENT_CODIGO = '{{ is_edit|default(false) ? conta.codigo : '' }}';
    let isInitialLoad = IS_EDIT;

    const NIVEL_TEXTS = {
        '1': {
            help: 'Classe e o nivel raiz do plano de contas. Exemplos: Ativo, Passivo, Receita, Despesa.',
            paiHelp: '',
            tipoHelp: 'Defina o tipo contabil desta classe.',
            codigoHelp: 'Informe o numero da classe (ex: 1, 2, 3)',
            aceitaHelp: 'Classes nao recebem lancamentos.',
            label: 'Classe'
        },
        '2': {
            help: 'Grupo e uma subdivisao dentro de uma Classe. Ex: dentro de "Receita", criar grupo "Receitas Operacionais".',
            paiHelp: 'Selecione a Classe onde este grupo sera criado.',
            tipoHelp: 'Herdado da classe pai.',
            codigoHelp: '',
            aceitaHelp: 'Grupos nao recebem lancamentos.',
            label: 'Grupo',
            paiNivel: 1
        },
        '3': {
            help: 'Subgrupo e uma subdivisao dentro de um Grupo. Ex: dentro de "Receitas Operacionais", criar "Taxas de Administracao".',
            paiHelp: 'Selecione o Grupo onde este subgrupo sera criado.',
            tipoHelp: 'Herdado do grupo pai.',
            codigoHelp: '',
            aceitaHelp: 'Subgrupos nao recebem lancamentos.',
            label: 'Subgrupo',
            paiNivel: 2
        },
        '4': {
            help: 'Conta e o nivel operacional — e aqui que os lancamentos sao registrados. Ex: "Taxa Adm. Locacao", "Energia Eletrica".',
            paiHelp: 'Selecione o Subgrupo onde esta conta sera criada.',
            tipoHelp: 'Herdado do subgrupo pai.',
            codigoHelp: '',
            aceitaHelp: 'Contas recebem lancamentos financeiros.',
            label: 'Conta',
            paiNivel: 3
        }
    };

    // Salvar todas as opcoes do pai para filtrar depois
    const allPaiOptions = [];
    for (let i = 0; i < paiSelect.options.length; i++) {
        const opt = paiSelect.options[i];
        allPaiOptions.push({
            value: opt.value,
            text: opt.text,
            nivel: opt.getAttribute('data-nivel'),
            tipo: opt.getAttribute('data-tipo'),
            selected: opt.selected
        });
    }

    function onNivelChange() {
        const nivel = nivelSelect.value;
        if (!nivel) {
            cardVinculacao.style.display = 'none';
            cardIdentificacao.style.display = 'none';
            cardOpcoes.style.display = 'none';
            nivelHelp.textContent = 'Selecione o nivel para ver a descricao.';
            return;
        }

        const config = NIVEL_TEXTS[nivel];

        // Mostrar cards
        cardVinculacao.style.display = '';
        cardIdentificacao.style.display = '';
        cardOpcoes.style.display = '';

        // Atualizar textos de ajuda
        nivelHelp.innerHTML = '<strong>' + config.label + ':</strong> ' + config.help;
        paiHelp.textContent = config.paiHelp;
        tipoHelp.textContent = config.tipoHelp;
        codigoHelp.textContent = config.codigoHelp;
        aceitaHelp.textContent = config.aceitaHelp;

        // Classe (1): sem pai, tipo manual, codigo livre
        if (nivel === '1') {
            paiWrapper.style.display = 'none';
            paiSelect.value = '';
            tipoSelect.disabled = false;
            tipoHelp.textContent = config.tipoHelp;
            mostrarCodigoSimples();
            codigoInput.setAttribute('placeholder', 'Ex: 1');
        } else {
            paiWrapper.style.display = '';
            filterPaiOptions(config.paiNivel);
        }

        // AceitaLancamentos: so para Conta (4)
        if (nivel === '4') {
            aceitaWrapper.style.display = '';
            aceitaCheckbox.checked = true;
            aceitaCheckbox.disabled = false;
        } else {
            aceitaWrapper.style.display = 'none';
            aceitaCheckbox.checked = false;
        }
    }

    function filterPaiOptions(targetNivel) {
        while (paiSelect.options.length > 0) {
            paiSelect.remove(0);
        }

        const placeholder = document.createElement('option');
        placeholder.value = '';
        placeholder.text = 'Selecione...';
        paiSelect.add(placeholder);

        let currentValue = null;
        allPaiOptions.forEach(function(opt) {
            if (opt.nivel === String(targetNivel)) {
                const option = document.createElement('option');
                option.value = opt.value;
                option.text = opt.text;
                option.setAttribute('data-nivel', opt.nivel);
                option.setAttribute('data-tipo', opt.tipo);
                if (opt.selected) {
                    option.selected = true;
                    currentValue = opt.value;
                }
                paiSelect.add(option);
            }
        });

        if (!currentValue) {
            paiSelect.value = '';
            mostrarCodigoSimples();
        }

        onPaiChange();
    }

    function onPaiChange() {
        const nivel = nivelSelect.value;
        if (nivel === '1') return;

        const selectedOption = paiSelect.options[paiSelect.selectedIndex];
        if (selectedOption && selectedOption.value) {
            // Herdar tipo do pai
            const paiTipo = selectedOption.getAttribute('data-tipo');
            if (paiTipo) {
                tipoSelect.value = paiTipo;
                tipoSelect.disabled = true;
            }
            // Buscar proximo codigo via API
            fetchProximoCodigo(selectedOption.value);
        } else {
            tipoSelect.disabled = false;
            mostrarCodigoSimples();
        }
    }

    function fetchProximoCodigo(paiId) {
        const url = API_URL.replace('__ID__', paiId);
        fetch(url)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.error) return;
                currentPrefixo = data.prefixo;
                mostrarCodigoComposto(data.prefixo, data.sufixo, data.padLen);
            })
            .catch(function() {
                mostrarCodigoSimples();
            });
    }

    function mostrarCodigoSimples() {
        codigoSimples.style.display = '';
        codigoComposto.style.display = 'none';
        currentPrefixo = '';
        codigoSugestao.textContent = '';
    }

    function mostrarCodigoComposto(prefixo, sufixo, padLen) {
        codigoSimples.style.display = 'none';
        codigoComposto.style.display = '';

        prefixoDisplay.textContent = prefixo;
        sufixoInput.setAttribute('maxlength', String(padLen + 1));
        sufixoInput.setAttribute('placeholder', sufixo);
        codigoSugestao.innerHTML = '<i class="fas fa-magic"></i> Proximo disponivel: <strong>' + prefixo + sufixo + '</strong>';

        // Em modo edicao na carga inicial: preservar o codigo atual, nao sobrescrever
        if (isInitialLoad && CURRENT_CODIGO && CURRENT_CODIGO.startsWith(prefixo)) {
            const editSufixo = CURRENT_CODIGO.substring(prefixo.length);
            sufixoInput.value = editSufixo;
            codigoInput.value = CURRENT_CODIGO;
            isInitialLoad = false;
        } else {
            sufixoInput.value = sufixo;
            codigoInput.value = prefixo + sufixo;
        }

        codigoInput.style.display = 'none';
    }

    // Sincronizar sufixo editavel com campo hidden do Symfony
    sufixoInput.addEventListener('input', function() {
        codigoInput.value = currentPrefixo + sufixoInput.value;
    });

    // Event listeners
    nivelSelect.addEventListener('change', onNivelChange);
    paiSelect.addEventListener('change', onPaiChange);

    // Re-habilitar tipo antes do submit
    document.getElementById('almasa-pc-form').addEventListener('submit', function() {
        tipoSelect.disabled = false;
        // Garantir que o codigo esta atualizado
        if (currentPrefixo && sufixoInput.value) {
            codigoInput.value = currentPrefixo + sufixoInput.value;
        }
        codigoInput.style.display = '';
    });

    // Inicializar (para edicao onde ja tem valor)
    if (nivelSelect.value) {
        onNivelChange();
        const nivel = nivelSelect.value;
        if (nivel !== '1') {
            const config = NIVEL_TEXTS[nivel];
            allPaiOptions.forEach(function(opt) {
                if (opt.selected && opt.nivel === String(config.paiNivel)) {
                    paiSelect.value = opt.value;
                }
            });
            onPaiChange();
        }
    }
})();
</script>
