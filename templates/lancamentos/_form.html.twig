{{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}

<ul class="nav nav-tabs mb-3" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-principal" type="button">
            <i class="fas fa-info-circle"></i> Dados Principais
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-pessoas" type="button">
            <i class="fas fa-users"></i> Pessoas
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-vinculos" type="button">
            <i class="fas fa-link"></i> Vínculos
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-documento" type="button">
            <i class="fas fa-file"></i> Documento
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-retencoes" type="button">
            <i class="fas fa-percentage"></i> Retenções
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-observacoes" type="button">
            <i class="fas fa-comment"></i> Observações
        </button>
    </li>
</ul>

<div class="tab-content">
    {# Tab Dados Principais #}
    <div class="tab-pane fade show active" id="tab-principal" role="tabpanel">
        <div class="row">
            <div class="col-md-2">
                {{ form_row(form.tipo) }}
            </div>
            <div class="col-md-2">
                {{ form_row(form.dataMovimento) }}
            </div>
            <div class="col-md-2">
                {{ form_row(form.dataVencimento) }}
            </div>
            <div class="col-md-2">
                {{ form_row(form.competencia) }}
            </div>
            <div class="col-md-4">
                <label class="form-label">Tipo de Lançamento (legado)</label>
                <div class="autocomplete-wrapper position-relative" data-url="{{ path('app_autocomplete_plano_contas') }}" data-hidden="#{{ form.planoContaId.vars.id }}" data-min="1"{% if planoContaPreload is defined and planoContaPreload %} data-preload-label="{{ planoContaPreload.label }}"{% endif %}>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                        <input type="text" class="form-control autocomplete-display" placeholder="Digite código ou descrição..." autocomplete="off">
                    </div>
                    <div class="autocomplete-results list-group shadow" style="display:none; position:absolute; z-index:1000; width:100%; max-height:250px; overflow-y:auto;"></div>
                </div>
                {{ form_widget(form.planoContaId) }}
            </div>
        </div>

        {# Plano de Contas — aceita entrada simples ou partida dobrada #}
        <div class="row mt-2">
            <div class="col-12">
                <div class="card border-primary">
                    <div class="card-header py-2 bg-transparent">
                        <i class="fas fa-sitemap text-primary"></i>
                        <strong>Plano de Contas</strong>
                        <small class="text-muted ms-1">— preencha apenas o campo necessário ou ambos para partida dobrada</small>
                    </div>
                    <div class="card-body py-2">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Conta Débito <small class="text-muted">(opcional)</small></label>
                                <select class="form-select form-select-sm mb-1" id="plano_debito_tipo">
                                    <option value="despesa" selected>Despesa</option>
                                    <option value="ativo">Ativo</option>
                                    <option value="passivo">Passivo</option>
                                    <option value="receita">Receita</option>
                                    <option value="patrimonio_liquido">Patrimônio Líquido</option>
                                    <option value="">Todos</option>
                                </select>
                                <div class="plano-conta-autocomplete-wrapper position-relative">
                                    <div class="input-group">
                                        <button type="button" class="btn btn-outline-secondary" id="plano_debito_lupa" title="Mostrar todas">
                                            <i class="fas fa-search"></i>
                                        </button>
                                        <input type="text" id="plano_debito_display" class="form-control"
                                               placeholder="Digite código ou descrição..." autocomplete="off">
                                        <button type="button" class="btn btn-outline-secondary" id="plano_debito_clear" title="Limpar" style="display:none">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                    <div id="plano_debito_results" class="plano-conta-results list-group shadow" style="display:none; position:absolute; z-index:1000; width:100%; max-height:250px; overflow-y:auto;"></div>
                                </div>
                                {{ form_widget(form.planoContaDebito) }}
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Conta Crédito <small class="text-muted">(opcional)</small></label>
                                <select class="form-select form-select-sm mb-1" id="plano_credito_tipo">
                                    <option value="receita" selected>Receita</option>
                                    <option value="ativo">Ativo</option>
                                    <option value="passivo">Passivo</option>
                                    <option value="despesa">Despesa</option>
                                    <option value="patrimonio_liquido">Patrimônio Líquido</option>
                                    <option value="">Todos</option>
                                </select>
                                <div class="plano-conta-autocomplete-wrapper position-relative">
                                    <div class="input-group">
                                        <button type="button" class="btn btn-outline-secondary" id="plano_credito_lupa" title="Mostrar todas">
                                            <i class="fas fa-search"></i>
                                        </button>
                                        <input type="text" id="plano_credito_display" class="form-control"
                                               placeholder="Digite código ou descrição..." autocomplete="off">
                                        <button type="button" class="btn btn-outline-secondary" id="plano_credito_clear" title="Limpar" style="display:none">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                    <div id="plano_credito_results" class="plano-conta-results list-group shadow" style="display:none; position:absolute; z-index:1000; width:100%; max-height:250px; overflow-y:auto;"></div>
                                </div>
                                {{ form_widget(form.planoContaCredito) }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-2">
                {{ form_row(form.valor) }}
            </div>
            <div class="col-md-2">
                {{ form_row(form.valorDesconto) }}
            </div>
            <div class="col-md-2">
                {{ form_row(form.valorJuros) }}
            </div>
            <div class="col-md-2">
                {{ form_row(form.valorMulta) }}
            </div>
            <div class="col-md-4">
                {{ form_row(form.centroCusto) }}
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                {{ form_row(form.historico) }}
            </div>
        </div>

        {% if not lancamento.id %}
        {# Recorrência — exibida apenas no formulário de criação #}
        <div class="row mt-2">
            <div class="col-12">
                <div class="card border-secondary">
                    <div class="card-header py-2 bg-transparent">
                        <i class="fas fa-sync-alt text-secondary"></i>
                        <strong>Recorrência</strong>
                        <small class="text-muted ms-1">— opcional, cria lançamentos futuros automaticamente</small>
                    </div>
                    <div class="card-body py-2">
                        <div class="row align-items-end g-3">
                            <div class="col-md-4">
                                {{ form_row(form.recorrenciaTipo) }}
                            </div>
                            <div class="col-md-2" id="recorrencia_qtd_wrapper" style="display:none">
                                {{ form_row(form.recorrenciaQtd) }}
                            </div>
                            <div class="col" id="recorrencia_info" style="display:none">
                                <div class="alert alert-info py-2 mb-3">
                                    <i class="fas fa-info-circle"></i>
                                    <span id="recorrencia_preview"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}
    </div>

    {# Tab Pessoas #}
    <div class="tab-pane fade" id="tab-pessoas" role="tabpanel">
        <div class="row">
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label">Credor / Fornecedor</label>
                    <div class="pessoa-autocomplete-wrapper position-relative">
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-search"></i></span>
                            <input type="text"
                                   id="credor_display"
                                   class="form-control"
                                   placeholder="Digite parte do nome..."
                                   autocomplete="off">
                        </div>
                        <div id="credor_results" class="pessoa-autocomplete-results list-group shadow" style="display:none; position:absolute; z-index:1000; width:100%;"></div>
                    </div>
                    {{ form_widget(form.pessoaCredorId) }}
                    <small class="text-muted">Fornecedor, prestador de servico, etc.</small>
                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label">Pagador / Cliente</label>
                    <div class="pessoa-autocomplete-wrapper position-relative">
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-search"></i></span>
                            <input type="text"
                                   id="pagador_display"
                                   class="form-control"
                                   placeholder="Digite parte do nome..."
                                   autocomplete="off">
                        </div>
                        <div id="pagador_results" class="pessoa-autocomplete-results list-group shadow" style="display:none; position:absolute; z-index:1000; width:100%;"></div>
                    </div>
                    {{ form_widget(form.pessoaPagadorId) }}
                    <small class="text-muted">Cliente, inquilino, etc.</small>
                </div>
            </div>
        </div>
    </div>

    {# Tab Vínculos #}
    <div class="tab-pane fade" id="tab-vinculos" role="tabpanel">
        <div class="row mb-2">
            <div class="col-12">
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" id="filtro_conta_proprietario" checked>
                    <label class="form-check-label" for="filtro_conta_proprietario">
                        <i class="fas fa-filter"></i> Incluir contas de proprietários na busca
                    </label>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-4">
                <label class="form-label">Contrato</label>
                <div class="autocomplete-wrapper position-relative" data-url="{{ path('app_autocomplete_contratos') }}" data-hidden="#{{ form.contratoId.vars.id }}" data-min="1"{% if contratoPreload is defined and contratoPreload %} data-preload-label="{{ contratoPreload.label }}"{% endif %}>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                        <input type="text" class="form-control autocomplete-display" placeholder="Buscar contrato..." autocomplete="off">
                    </div>
                    <div class="autocomplete-results list-group shadow" style="display:none; position:absolute; z-index:1000; width:100%; max-height:250px; overflow-y:auto;"></div>
                </div>
                {{ form_widget(form.contratoId) }}
            </div>
            <div class="col-md-4">
                <label class="form-label">Imóvel</label>
                <div class="autocomplete-wrapper position-relative" data-url="{{ path('app_autocomplete_imoveis') }}" data-hidden="#{{ form.imovelId.vars.id }}" data-min="1"{% if imovelPreload is defined and imovelPreload %} data-preload-label="{{ imovelPreload.label }}"{% endif %}>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                        <input type="text" class="form-control autocomplete-display" placeholder="Buscar imóvel..." autocomplete="off">
                    </div>
                    <div class="autocomplete-results list-group shadow" style="display:none; position:absolute; z-index:1000; width:100%; max-height:250px; overflow-y:auto;"></div>
                </div>
                {{ form_widget(form.imovelId) }}
            </div>
            <div class="col-md-4">
                <label class="form-label">Conta Bancária</label>
                <div class="pessoa-autocomplete-wrapper position-relative">
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                        <input type="text" id="cb_vinc_geral_display" class="form-control"
                               placeholder="Buscar conta bancária..." autocomplete="off">
                        <button type="button" class="btn btn-outline-secondary" id="cb_vinc_geral_clear" style="display:none">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                    <div id="cb_vinc_geral_results" class="list-group shadow" style="display:none; position:absolute; z-index:1000; width:100%; max-height:200px; overflow-y:auto;"></div>
                </div>
                <input type="hidden" id="cb_vinc_geral_hidden" value="">
            </div>
        </div>
        <div class="row mt-3">
            <div class="col-md-6" id="cb_vinc_debito_wrapper" style="display:none">
                <label class="form-label"><span class="badge bg-info me-1">Débito</span> Conta Bancária</label>
                <div class="pessoa-autocomplete-wrapper position-relative">
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                        <input type="text" id="cb_vinc_debito_display" class="form-control"
                               placeholder="Buscar conta bancária..." autocomplete="off">
                        <button type="button" class="btn btn-outline-secondary" id="cb_vinc_debito_clear" style="display:none">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                    <div id="cb_vinc_debito_results" class="list-group shadow" style="display:none; position:absolute; z-index:1000; width:100%; max-height:200px; overflow-y:auto;"></div>
                </div>
                <input type="hidden" id="cb_vinc_debito_hidden" value="">
                <div id="cb_vinc_debito_msg" class="text-muted small mt-1" style="display:none"></div>
            </div>
            <div class="col-md-6" id="cb_vinc_credito_wrapper" style="display:none">
                <label class="form-label"><span class="badge bg-success me-1">Crédito</span> Conta Bancária</label>
                <div class="pessoa-autocomplete-wrapper position-relative">
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                        <input type="text" id="cb_vinc_credito_display" class="form-control"
                               placeholder="Buscar conta bancária..." autocomplete="off">
                        <button type="button" class="btn btn-outline-secondary" id="cb_vinc_credito_clear" style="display:none">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                    <div id="cb_vinc_credito_results" class="list-group shadow" style="display:none; position:absolute; z-index:1000; width:100%; max-height:200px; overflow-y:auto;"></div>
                </div>
                <input type="hidden" id="cb_vinc_credito_hidden" value="">
                <div id="cb_vinc_credito_msg" class="text-muted small mt-1" style="display:none"></div>
            </div>
        </div>
        {{ form_widget(form.contaBancariaId) }}
    </div>

    {# Tab Documento #}
    <div class="tab-pane fade" id="tab-documento" role="tabpanel">
        <div class="row">
            <div class="col-md-3">
                {{ form_row(form.tipoDocumento) }}
            </div>
            <div class="col-md-3">
                {{ form_row(form.numeroDocumento) }}
            </div>
            <div class="col-md-3">
                {{ form_row(form.formaPagamento) }}
            </div>
        </div>
    </div>

    {# Tab Retenções #}
    <div class="tab-pane fade" id="tab-retencoes" role="tabpanel">
        <div class="row">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">INSS</div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-check mt-4">
                                    {{ form_widget(form.reterInss) }}
                                    {{ form_label(form.reterInss) }}
                                </div>
                            </div>
                            <div class="col-md-4">
                                {{ form_row(form.percInss) }}
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Valor INSS</label>
                                <input type="text" class="form-control" id="valorInss" readonly>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">ISS</div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-check mt-4">
                                    {{ form_widget(form.reterIss) }}
                                    {{ form_label(form.reterIss) }}
                                </div>
                            </div>
                            <div class="col-md-4">
                                {{ form_row(form.percIss) }}
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Valor ISS</label>
                                <input type="text" class="form-control" id="valorIss" readonly>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Tab Observações #}
    <div class="tab-pane fade" id="tab-observacoes" role="tabpanel">
        <div class="row">
            <div class="col-md-12">
                {{ form_row(form.observacoes) }}
            </div>
        </div>
    </div>
</div>

<hr>

<div class="d-flex justify-content-between">
    <a href="{{ path('app_lancamentos_index') }}" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Voltar
    </a>
    <button type="submit" class="btn btn-primary">
        <i class="fas fa-check"></i> Salvar
    </button>
</div>

{{ form_end(form) }}

{# Modal — Conta Bancária com busca inteligente #}
<div class="modal fade" id="modalContaBancaria" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title"><i class="fas fa-university"></i> Vincular Conta Bancária</h5>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-3">Informe a conta bancária de cada conta do plano envolvida na transferência <small>(pelo menos uma)</small>:</p>

                {# Conta Débito #}
                <div class="card mb-3">
                    <div class="card-body py-2">
                        <label class="form-label mb-1">
                            <span class="badge bg-info me-1">Débito</span>
                            <strong id="modal_nome_debito"></strong>
                        </label>
                        <div class="pessoa-autocomplete-wrapper position-relative">
                            <div class="input-group input-group-sm">
                                <span class="input-group-text"><i class="fas fa-search"></i></span>
                                <input type="text" id="modal_cb_deb_display" class="form-control"
                                       placeholder="Buscar conta bancária..." autocomplete="off">
                                <button type="button" class="btn btn-outline-secondary" id="modal_cb_deb_clear" style="display:none">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>
                            <div id="modal_cb_deb_results" class="list-group shadow" style="display:none; position:absolute; z-index:1060; width:100%; max-height:180px; overflow-y:auto;"></div>
                        </div>
                        <input type="hidden" id="modal_cb_deb_hidden" value="">
                        <input type="hidden" id="modal_cb_deb_plano_id" value="">
                    </div>
                </div>

                {# Conta Crédito #}
                <div class="card">
                    <div class="card-body py-2">
                        <label class="form-label mb-1">
                            <span class="badge bg-success me-1">Crédito</span>
                            <strong id="modal_nome_credito"></strong>
                        </label>
                        <div class="pessoa-autocomplete-wrapper position-relative">
                            <div class="input-group input-group-sm">
                                <span class="input-group-text"><i class="fas fa-search"></i></span>
                                <input type="text" id="modal_cb_cred_display" class="form-control"
                                       placeholder="Buscar conta bancária..." autocomplete="off">
                                <button type="button" class="btn btn-outline-secondary" id="modal_cb_cred_clear" style="display:none">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>
                            <div id="modal_cb_cred_results" class="list-group shadow" style="display:none; position:absolute; z-index:1060; width:100%; max-height:180px; overflow-y:auto;"></div>
                        </div>
                        <input type="hidden" id="modal_cb_cred_hidden" value="">
                        <input type="hidden" id="modal_cb_cred_plano_id" value="">
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" id="btnConfirmarContaBancaria">
                    <i class="fas fa-check"></i> Confirmar e Salvar
                </button>
            </div>
        </div>
    </div>
</div>

<script src="{{ asset('js/generic_autocomplete.js') }}"></script>
<script>
window.LANCAMENTOS_CONTA_BANCARIA_URL = '{{ path("app_lancamentos_conta_bancaria_autocomplete") }}';
window.LANCAMENTOS_VINCULOS_URL = '{{ path("app_lancamentos_contas_bancarias_por_plano", {"planoId": "__PLANO_ID__"}) }}';
window.LANCAMENTOS_CRIAR_VINCULO_URL = '{{ path("app_lancamentos_criar_vinculo") }}';
window.LANCAMENTOS_PLANO_CONTA = {
    url: '{{ path("app_almasa_plano_contas_api_busca") }}',
    debito: {
        displayId:  'plano_debito_display',
        hiddenId:   '{{ form.planoContaDebito.vars.id }}',
        resultsId:  'plano_debito_results',
        clearId:    'plano_debito_clear',
        lupaId:     'plano_debito_lupa',
        tipoSelectId: 'plano_debito_tipo',
        preloadId:  '{{ planoDebitoPreload ? planoDebitoPreload.id : '' }}',
        preloadLabel: '{{ planoDebitoPreload ? (planoDebitoPreload.codigo ~ ' - ' ~ planoDebitoPreload.descricao)|e('js') : '' }}'
    },
    credito: {
        displayId:  'plano_credito_display',
        hiddenId:   '{{ form.planoContaCredito.vars.id }}',
        resultsId:  'plano_credito_results',
        clearId:    'plano_credito_clear',
        lupaId:     'plano_credito_lupa',
        tipoSelectId: 'plano_credito_tipo',
        preloadId:  '{{ planoCreditoPreload ? planoCreditoPreload.id : '' }}',
        preloadLabel: '{{ planoCreditoPreload ? (planoCreditoPreload.codigo ~ ' - ' ~ planoCreditoPreload.descricao)|e('js') : '' }}'
    }
};
window.LANCAMENTOS_AUTOCOMPLETE = {
    url: "{{ path('app_lancamentos_pessoa_autocomplete') }}",
    credor: {
        displayId: 'credor_display',
        hiddenId: '{{ form.pessoaCredorId.vars.id }}',
        resultsId: 'credor_results',
        preloadNome: "{{ credorPreload ? credorPreload.nome|e('js') : '' }}",
        preloadId: "{{ credorPreload ? credorPreload.id : '' }}"
    },
    pagador: {
        displayId: 'pagador_display',
        hiddenId: '{{ form.pessoaPagadorId.vars.id }}',
        resultsId: 'pagador_results',
        preloadNome: "{{ pagadorPreload ? pagadorPreload.nome|e('js') : '' }}",
        preloadId: "{{ pagadorPreload ? pagadorPreload.id : '' }}"
    }
};

// Preload hidden field values for autocomplete fields (contrato, imovel, planoConta)
document.addEventListener('DOMContentLoaded', function () {
    {% if planoContaPreload is defined and planoContaPreload %}
    var pcHidden = document.getElementById('{{ form.planoContaId.vars.id }}');
    if (pcHidden) pcHidden.value = '{{ planoContaPreload.id }}';
    {% endif %}
    {% if contratoPreload is defined and contratoPreload %}
    var ctHidden = document.getElementById('{{ form.contratoId.vars.id }}');
    if (ctHidden) ctHidden.value = '{{ contratoPreload.id }}';
    {% endif %}
    {% if imovelPreload is defined and imovelPreload %}
    var imHidden = document.getElementById('{{ form.imovelId.vars.id }}');
    if (imHidden) imHidden.value = '{{ imovelPreload.id }}';
    {% endif %}
});
</script>
