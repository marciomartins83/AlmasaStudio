{% extends 'base.html.twig' %}

{% block title %}Novo Vinculo Bancario - {{ parent() }}{% endblock %}

{% block content %}
<div class="container-fluid">
    {% include '_partials/breadcrumb.html.twig' with {
        'items': [
            {'label': 'Financeiro', 'url': '#'},
            {'label': 'Vinculos Bancarios', 'url': path('app_almasa_vinculo_bancario_index')}
        ],
        'current': 'Novo Vinculo'
    } %}
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h1><i class="fas fa-plus"></i> Novo Vinculo Bancario</h1>
                <a href="{{ path('app_almasa_vinculo_bancario_index') }}" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Voltar
                </a>
            </div>

            <div class="card">
                <div class="card-header bg-light">
                    <i class="fas fa-info-circle text-primary"></i>
                    Vincule uma conta bancaria a uma conta do plano de contas para classificacao contabil automatica.
                </div>
                <div class="card-body">
                    {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': true}}) }}
                        <div class="row">
                            <div class="col-md-6">
                                {{ form_row(form.contaBancaria) }}
                            </div>
                            <div class="col-md-6">
                                {{ form_row(form.almasaPlanoConta) }}
                            </div>
                        </div>
                        <div class="row mt-2">
                            <div class="col-md-10">
                                {{ form_row(form.observacao) }}
                            </div>
                            <div class="col-md-2 d-flex align-items-end pb-3">
                                <div class="form-check">
                                    {{ form_widget(form.ativo) }}
                                    {{ form_label(form.ativo) }}
                                </div>
                            </div>
                        </div>
                        <div class="row mt-3">
                            <div class="col-12">
                                <button type="submit" class="btn btn-success">
                                    <i class="fas fa-save"></i> Salvar
                                </button>
                                <a href="{{ path('app_almasa_vinculo_bancario_index') }}" class="btn btn-secondary ms-2">
                                    <i class="fas fa-times"></i> Cancelar
                                </a>
                            </div>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
