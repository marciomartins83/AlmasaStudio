{% extends 'base.html.twig' %}

{% block title %}Editar Vinculo Bancario - {{ parent() }}{% endblock %}

{% block content %}
<div class="container-fluid">
    {% include '_partials/breadcrumb.html.twig' with {
        'items': [
            {'label': 'Financeiro', 'url': '#'},
            {'label': 'Vinculos Bancarios', 'url': path('app_almasa_vinculo_bancario_index')}
        ],
        'current': 'Editar Vinculo #' ~ vinculo.id
    } %}
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h1><i class="fas fa-edit"></i> Editar Vinculo #{{ vinculo.id }}</h1>
                <div>
                    <a href="{{ path('app_almasa_vinculo_bancario_show', {'id': vinculo.id}) }}" class="btn btn-info">
                        <i class="fas fa-eye"></i> Visualizar
                    </a>
                    <a href="{{ path('app_almasa_vinculo_bancario_index') }}" class="btn btn-secondary ms-2">
                        <i class="fas fa-arrow-left"></i> Voltar
                    </a>
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': true}}) }}

                        {% include 'almasa_vinculo_bancario/_form.html.twig' %}

                        <div class="row mt-3">
                            <div class="col-12">
                                <button type="submit" class="btn btn-success">
                                    <i class="fas fa-save"></i> Salvar Alteracoes
                                </button>
                                <a href="{{ path('app_almasa_vinculo_bancario_show', {'id': vinculo.id}) }}" class="btn btn-info ms-2">
                                    <i class="fas fa-eye"></i> Ver
                                </a>
                                <a href="{{ path('app_almasa_vinculo_bancario_index') }}" class="btn btn-secondary ms-2">
                                    <i class="fas fa-times"></i> Cancelar
                                </a>
                            </div>
                        </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="{{ asset('js/generic_autocomplete.js') }}"></script>
{{ encore_entry_script_tags('pessoa_autocomplete') }}
{{ encore_entry_script_tags('vinculo_bancario') }}
{% endblock %}
